<section class="mx-auto w-full max-w-md">
  <div class="card bg-base-200 shadow-sm">
    <div class="card-body">
      <h1 class="card-title text-2xl font-bold">Email preferences</h1>
      <p class="mt-1 text-sm text-base-content/60">Choose which emails you'd like to receive at <%= @user.email %>.</p>

      <% if @highlighted_category %>
        <div class="alert alert-info mt-4 text-sm">
          You clicked unsubscribe from "<%= @highlighted_category.titleize %>" - uncheck it below and save to confirm.
        </div>
      <% end %>

      <%= form_with url: email_preference_path(params[:token]), method: :patch, html: { class: "mt-4 space-y-3" } do %>
        <% EmailCampaign::OPTIONAL_CATEGORIES.each do |category| %>
          <label class="label cursor-pointer justify-start gap-3 rounded-lg border p-3 <%= category == @highlighted_category ? "border-primary" : "border-base-300" %>">
            <input type="checkbox" name="subscribed[<%= category %>]" value="1"
                   class="checkbox-field"
                   <%= "checked" if @user.subscribed_to_email_category?(category) %>>
            <span class="label-text"><%= category.titleize %></span>
          </label>
        <% end %>

        <div class="form-control mt-4">
          <%= submit_tag "Save preferences", class: "btn btn-primary w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</section>
