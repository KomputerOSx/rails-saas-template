<section class="mx-auto w-full max-w-md">
  <div class="card bg-base-200 shadow-sm">
    <div class="card-body">
      <h1 class="card-title text-2xl font-bold">Link invalid</h1>
      <p class="mt-2 text-sm text-base-content/60">This email preferences link is invalid. If you'd like to change what emails you receive, log in and visit your profile page instead.</p>

      <div class="form-control mt-4">
        <%= link_to "Go to login", login_path, class: "btn btn-primary w-full" %>
      </div>
    </div>
  </div>
</section>
