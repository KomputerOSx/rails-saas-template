<section class="w-full max-w-5xl">
  <p class="text-sm font-medium text-base-content/60">Admin</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">Notifications</h1>

  <div class="mt-4">
    <%= link_to "New notification", new_admin_notification_path, class: "btn btn-primary btn-sm" %>
  </div>

  <%= turbo_frame_tag "admin_notifications_index_frame" do %>
    <%= form_with url: admin_notifications_path, method: :get, html: { class: "mt-6 flex flex-wrap items-end gap-2" } do %>
      <div class="form-control">
        <label class="label"><span class="label-text text-xs">Search</span></label>
        <input type="text" name="q" value="<%= @q %>" placeholder="Title" class="input-field w-56">
      </div>
      <div class="form-control">
        <label class="label"><span class="label-text text-xs">Status</span></label>
        <select name="status" class="select-field">
          <option value="">All statuses</option>
          <option value="active" <%= "selected" if @status == "active" %>>Active</option>
          <option value="withdrawn" <%= "selected" if @status == "withdrawn" %>>Withdrawn</option>
        </select>
      </div>
      <%= submit_tag "Filter", class: "btn btn-sm btn-primary" %>
      <% if @q.present? || @status.present? %>
        <%= link_to "Clear", admin_notifications_path, class: "btn btn-sm btn-ghost" %>
      <% end %>
    <% end %>

    <div class="card mt-4 border border-base-300">
      <div class="card-body p-0">
        <div class="overflow-x-auto">
          <table class="table table-sm">
            <thead class="text-sm font-semibold text-base-content bg-base-200">
              <tr class="border-b border-base-300">
                <th>Title</th>
                <th>Created by</th>
                <th>Recipients</th>
                <th>Status</th>
                <th>Created at</th>
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              <%= render partial: "admin/notifications/row", collection: @notifications, as: :notification %>
            </tbody>
          </table>
          <% if @notifications.none? %>
            <p class="px-8 py-6 text-sm text-base-content/60">No notifications match your search.</p>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</section>
