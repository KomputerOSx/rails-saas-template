<section class="w-full max-w-3xl">
  <p class="text-sm font-medium text-base-content/60">Admin</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">New Notification</h1>

  <div class="mt-8 card bg-base-200 border border-base-300/30 shadow-sm">
    <div class="card-body">
      <%= form_with url: admin_notifications_path, method: :post, html: { class: "space-y-4" } do %>
        <div class="form-control">
          <label class="label"><span class="label-text">Title</span></label>
          <%= text_field_tag "notification[title]", nil, class: "input-field" %>
        </div>

        <div class="form-control">
          <label class="label"><span class="label-text">Body</span></label>
          <%= text_area_tag "notification[body]", nil, class: "textarea-field", rows: 4 %>
        </div>

        <div class="form-control">
          <label class="label cursor-pointer justify-start gap-2">
            <%= check_box_tag "notification[send_to_all]", "1" %>
            <span class="label-text">Send to all users</span>
          </label>
        </div>

        <div class="form-control">
          <label class="label"><span class="label-text">Or pick specific users</span></label>
          <%= select_tag "notification[user_ids][]", options_from_collection_for_select(@users, :id, :email),
                multiple: true, class: "select-field h-40" %>
          <p class="mt-1 text-xs text-base-content/60">If "Send to all users" is checked, this list is ignored.</p>
        </div>

        <%= submit_tag "Send", class: "btn btn-primary" %>
      <% end %>
    </div>
  </div>
</section>
