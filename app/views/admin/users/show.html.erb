<section class="w-full max-w-3xl">
  <div class="flex items-start justify-between">
    <div>
      <p class="text-sm font-medium text-base-content/60">
        <%= link_to "Users", admin_users_path, class: "hover:text-base-content" %>
        <span class="mx-1">/</span>
        <span><%= @user.email %></span>
      </p>
      <h1 class="mt-3 text-4xl font-semibold tracking-normal">
        <%= [ @user.first_name, @user.last_name ].compact_blank.join(" ").presence || @user.email %>
      </h1>
    </div>
    <%= link_to "Back", admin_users_path, class: "btn btn-outline shrink-0" %>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-2">
    <div data-controller="modal">
      <button data-action="click->modal#open" class="btn btn-sm btn-outline">Edit</button>
      <dialog data-modal-target="dialog" class="modal"<%= " open".html_safe if @user.errors.any? %>>
        <div class="modal-box">
          <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>
          <h3 class="font-bold text-lg mb-4">Edit user</h3>
          <%= form_with model: @user, url: admin_user_path(@user), method: :patch, html: { class: "space-y-4" } do |f| %>
            <div class="form-control">
              <%= f.label :first_name, class: "label" do %><span class="label-text">First name</span><% end %>
              <%= f.text_field :first_name, class: error_class_for(@user, :first_name, "input input-bordered w-full") %>
              <%= field_errors(@user, :first_name) %>
            </div>
            <div class="form-control">
              <%= f.label :last_name, class: "label" do %><span class="label-text">Last name</span><% end %>
              <%= f.text_field :last_name, class: error_class_for(@user, :last_name, "input input-bordered w-full") %>
              <%= field_errors(@user, :last_name) %>
            </div>
            <div class="form-control">
              <%= f.label :email, class: "label" do %><span class="label-text">Email</span><% end %>
              <%= f.email_field :email, class: error_class_for(@user, :email, "input input-bordered w-full") %>
              <%= field_errors(@user, :email) %>
            </div>
            <div class="form-control mt-2">
              <%= f.submit "Save", class: "btn btn-primary w-full" %>
            </div>
          <% end %>
        </div>
        <form method="dialog" class="modal-backdrop"><button>close</button></form>
      </dialog>
    </div>

    <%= button_to "Send reset link", send_reset_link_admin_user_path(@user), method: :post,
          class: "btn btn-sm btn-outline" %>
  </div>

  <%# ── User Information ── %>
  <div class="mt-8 card border border-base-300">
    <div class="card-body p-0">
      <dl class="divide-y divide-base-300">
        <div class="flex items-center justify-between px-8 py-4">
          <dt class="text-xs text-base-content/60 uppercase tracking-wide">Email</dt>
          <dd class="font-medium"><%= @user.email %></dd>
        </div>
        <div class="flex items-center justify-between px-8 py-4">
          <dt class="text-xs text-base-content/60 uppercase tracking-wide">First Name</dt>
          <dd class="font-medium"><%= @user.first_name.presence || "—" %></dd>
        </div>
        <div class="flex items-center justify-between px-8 py-4">
          <dt class="text-xs text-base-content/60 uppercase tracking-wide">Last Name</dt>
          <dd class="font-medium"><%= @user.last_name.presence || "—" %></dd>
        </div>
        <div class="flex items-center justify-between px-8 py-4">
          <dt class="text-xs text-base-content/60 uppercase tracking-wide">Role</dt>
          <dd class="flex flex-wrap gap-1">
            <% if @user.roles.any? %>
              <% @user.roles.each do |role| %>
                <span class=""><%= role.name %> (<%= role.scope%>)</span>
              <% end %>
            <% else %>
              <span class="text-base-content/50">—</span>
            <% end %>
          </dd>
        </div>
        <div class="flex items-center justify-between px-8 py-4">
          <dt class="text-xs text-base-content/60 uppercase tracking-wide">Account Status</dt>
          <dd>
            <% if @user.disabled? %>
              <span class="badge badge-error badge-sm">Disabled</span>
            <% elsif @user.locked? %>
              <span class="badge badge-warning badge-sm">Locked</span>
            <% else %>
              <span class="badge badge-success badge-sm">Active</span>
            <% end %>
          </dd>
        </div>
        <div class="flex items-center justify-between px-8 py-4">
          <dt class="text-xs text-base-content/60 uppercase tracking-wide">Last Sign In</dt>
          <dd class="font-medium">
            <% if @user.last_sign_in_at %>
              <%= @user.last_sign_in_at.strftime("%B %d, %Y at %I:%M %p") %>
              <span class="text-base-content/60">(<%= time_ago_in_words(@user.last_sign_in_at) %> ago)</span>
            <% else %>
              <span class="text-base-content/50">—</span>
            <% end %>
          </dd>
        </div>
        <div class="flex items-center justify-between px-8 py-4">
          <dt class="text-xs text-base-content/60 uppercase tracking-wide">Created</dt>
          <dd class="font-medium">
            <%= @user.created_at.strftime("%B %d, %Y at %I:%M %p") %>
            <span class="text-base-content/60">(<%= time_ago_in_words(@user.created_at) %> ago)</span>
          </dd>
        </div>
        <div class="flex items-center justify-between px-8 py-4">
          <dt class="text-xs text-base-content/60 uppercase tracking-wide">Last Updated</dt>
          <dd class="font-medium">
            <%= @user.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
            <span class="text-base-content/60">(<%= time_ago_in_words(@user.updated_at) %> ago)</span>
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <%# ── Organisation Assignments ── %>
  <div class="mt-10">
    <h2 class="text-lg font-semibold">Organisation Assignments</h2>
    <p class="mt-0.5 text-sm text-base-content/60">Organisations this user belongs to and their role in each.</p>

    <% if @memberships.any? %>
      <div class="card mt-4 border border-base-300">
        <div class="card-body p-0">
          <div class="overflow-x-auto">
            <table class="table table-sm">
              <thead class="text-base-content/60 text-xs uppercase tracking-wide">
                <tr class="border-b border-base-300">
                  <th>Organisation</th>
                  <th>Role</th>
                </tr>
              </thead>
              <tbody>
                <% @memberships.each do |membership| %>
                  <tr class="hover">
                    <td class="font-medium"><%= membership.organization.name %></td>
                    <td class="text-base-content/60"><%= membership.roles.map(&:name).join(", ").presence || "—" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% else %>
      <p class="mt-4 text-sm text-base-content/60">This user does not belong to any organisation.</p>
    <% end %>
  </div>

  <%# ── System Roles (grant/revoke) ── %>
  <div class="mt-10">
    <h2 class="text-lg font-semibold">System Roles</h2>
    <p class="mt-0.5 text-sm text-base-content/60">System-scope roles grant admin-level access, independent of any organisation.</p>

    <div class="card mt-4 border border-base-300">
      <div class="card-body">
        <ul class="divide-y divide-base-300 max-w-md">
          <% @user.roles.each do |role| %>
            <li class="py-3 flex items-center justify-between gap-4">
              <span class=""><%= role.name %> (<%= role.scope%>)</span>
              <%= button_to "Revoke", admin_user_user_role_path(@user, role_id: role.id), method: :delete,
                    data: { turbo_confirm: "Revoke #{role.name} from #{@user.email}?" }, class: "btn btn-xs btn-error btn-outline" %>
            </li>
          <% end %>
        </ul>

        <% grantable_roles = @roles - @user.roles %>
        <% if grantable_roles.any? %>
          <%= form_with url: admin_user_user_role_path(@user), method: :post, html: { class: "mt-6 flex items-end gap-2" } do %>
            <div class="form-control">
              <label class="label"><span class="label-text">Grant role</span></label>
              <select name="role_id" class="select select-bordered select-sm">
                <% grantable_roles.each do |role| %>
                  <option value="<%= role.id %>"><%= role.name %> (<%= role.scope %>)</option>
                <% end %>
              </select>
            </div>
            <%= submit_tag "Grant", class: "btn btn-sm btn-primary" %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Danger Zone ── %>
  <div class="mt-10">
    <h2 class="text-lg font-semibold">Danger Zone</h2>

    <div class="card mt-4 border border-error">
      <div class="card-body p-0">
        <div class="flex items-center justify-between gap-4 px-8 py-4">
          <div>
            <% if @user.disabled? %>
              <p class="font-medium text-error">Re-enable account</p>
              <p class="text-sm text-base-content/60 mt-1">Restores login access for <%= @user.email %>.</p>
            <% else %>
              <p class="font-medium text-error">Disable account</p>
              <p class="text-sm text-base-content/60 mt-1">
                The user will be signed out everywhere and unable to log in until re-enabled. This does not delete their data.
              </p>
            <% end %>
          </div>
          <% if @user.disabled? %>
            <%= button_to "Enable Account", enable_admin_user_path(@user), method: :patch,
                  class: "btn btn-outline btn-sm shrink-0" %>
          <% else %>
            <%= button_to "Disable", disable_admin_user_path(@user), method: :patch,
                  data: { controller: "confirm-modal", action: "click->confirm-modal#confirm",
                          confirm_modal_message_value: "Disable #{@user.email}? They will be signed out everywhere and unable to log in." },
                  class: "btn btn-error btn-outline btn-sm shrink-0" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
