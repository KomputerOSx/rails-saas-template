<section class="w-full max-w-3xl">
  <p class="text-sm font-medium text-base-content/60">Admin</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">System Admin Dashboard</h1>

  <p class="mt-4 text-sm text-base-content/70">
    <%= @user_count %> users &middot;
    <%= @role_count %> roles &middot;
    <%= @permission_count %> permissions &middot;
    <%= @audit_log_count %> audit log entries &middot;
    <%= @notification_count %> active notifications
  </p>

  <div class="mt-8 space-y-8">
    <div>
      <h2 class="text-lg font-semibold">RBAC &amp; Admin</h2>
      <ul class="mt-2 list-disc list-inside space-y-1">
        <li><%= link_to "Dashboard", admin_root_path, class: "link" %> — this page</li>
        <li><%= link_to "Users", admin_users_path, class: "link" %> — list users, view roles, grant/revoke roles</li>
        <li><%= link_to "Roles", admin_roles_path, class: "link" %> — create, edit, and delete roles; assign permissions</li>
        <li><%= link_to "Permissions", admin_permissions_path, class: "link" %> — create, edit, and delete permissions</li>
        <li><%= link_to "Audit logs", admin_audit_logs_path, class: "link" %> — security/activity event log</li>
        <li><%= link_to "Notifications", admin_notifications_path, class: "link" %> — send/withdraw system messages</li>
        <li><%= link_to "Maintenance mode", edit_admin_maintenance_mode_path, class: "link" %> — <%= @maintenance_status[:enabled] ? "currently ON" : "currently off" %></li>
      </ul>
    </div>

    <div>
      <h2 class="text-lg font-semibold">Authentication</h2>
      <ul class="mt-2 list-disc list-inside space-y-1">
        <li><%= link_to "Login", login_path, class: "link" %></li>
        <li><%= link_to "Sign up", new_registration_path, class: "link" %></li>
        <li><%= link_to "Confirm email", new_confirmation_path, class: "link" %> — 6-digit code confirmation</li>
        <li><%= link_to "Forgot password", new_password_reset_path, class: "link" %></li>
      </ul>
    </div>

    <div>
      <h2 class="text-lg font-semibold">Account</h2>
      <ul class="mt-2 list-disc list-inside space-y-1">
        <li><%= link_to "Profile", profile_path, class: "link" %> — details, roles, password, danger zone</li>
        <li><%= link_to "Change password", edit_password_path, class: "link" %></li>
        <li><%= link_to "Set up authenticator app (TOTP)", new_profile_totp_path, class: "link" %></li>
      </ul>
    </div>

    <div>
      <h2 class="text-lg font-semibold">General</h2>
      <ul class="mt-2 list-disc list-inside space-y-1">
        <li><%= link_to "Home", root_path, class: "link" %></li>
        <li><%= link_to "Dashboard", dashboard_path, class: "link" %></li>
      </ul>
    </div>
  </div>
</section>
