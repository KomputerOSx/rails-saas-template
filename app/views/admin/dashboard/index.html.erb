<section class="w-full max-w-3xl">
  <p class="text-sm font-medium text-base-content/60">Admin</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">System Admin Dashboard</h1>

  <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div class="card bg-base-200 border border-base-300/30 shadow-sm">
      <div class="card-body">
        <p class="text-xs text-base-content/60">Users</p>
        <p class="text-3xl font-semibold"><%= @user_count %></p>
        <%= link_to "Manage users", admin_users_path, class: "link link-primary text-sm" %>
      </div>
    </div>

    <div class="card bg-base-200 border border-base-300/30 shadow-sm">
      <div class="card-body">
        <p class="text-xs text-base-content/60">Roles</p>
        <p class="text-3xl font-semibold"><%= @role_count %></p>
        <%= link_to "View roles", admin_roles_path, class: "link link-primary text-sm" %>
      </div>
    </div>
  </div>

  <div class="mt-8">
    <h2 class="text-xl font-semibold mb-4">Recent audit activity</h2>
    <div class="card bg-base-200 border border-base-300/30 shadow-sm">
      <div class="card-body">
        <ul class="divide-y divide-base-300/30">
          <% @recent_audit_logs.each do |log| %>
            <li class="py-2 flex items-center justify-between gap-4 text-sm">
              <span><%= log.event_type.humanize %><%= " — #{log.user.email}" if log.user %></span>
              <span class="text-base-content/50"><%= time_ago_in_words(log.created_at) %> ago</span>
            </li>
          <% end %>
        </ul>
        <%= link_to "View all audit logs", admin_audit_logs_path, class: "link link-primary text-sm mt-2" %>
      </div>
    </div>
  </div>
</section>
