<section class="w-full max-w-2xl">
  <div class="flex items-start justify-between">
    <div>
      <p class="text-sm font-medium text-base-content/60">
        <%= link_to "Features", admin_features_path, class: "hover:text-base-content" %>
        <span class="mx-1">/</span>
        <span><%= @feature.key %></span>
      </p>
      <h1 class="mt-3 text-4xl font-semibold tracking-normal"><%= @feature.name %></h1>
    </div>
    <%= link_to "Back", admin_features_path, class: "btn btn-outline btn-sm shrink-0" %>
  </div>

  <div class="mt-8 card border border-base-300">
    <div class="card-body">
      <%= form_with model: @feature, url: admin_feature_path(@feature), method: :patch, html: { class: "space-y-4" } do |f| %>
        <%= render "form", f: f %>
      <% end %>
    </div>
  </div>
</section>
