<div class="form-control">
  <label class="label"><span class="label-text">Key</span></label>
  <p class="font-mono text-sm"><%= @feature.key %></p>
  <p class="mt-1 text-xs text-base-content/60">
    Features are defined in <code>config/features.yml</code> - the key can't be changed here.
  </p>
</div>

<div class="form-control">
  <label class="label cursor-pointer justify-start gap-2">
    <%= f.check_box :applies_to_all_organizations, class: "checkbox-field" %>
    <span class="label-text">Apply to all organizations (including ones created in the future)</span>
  </label>
  <p class="mt-1 text-xs text-base-content/60">
    When checked, every organization gets access automatically - including ones that don't exist
    yet. The list below is ignored (and left untouched, in case this is turned off later) while
    this is on.
  </p>
</div>

<div class="form-control">
  <label class="label"><span class="label-text">Organization access</span></label>
  <div class="card border border-base-300">
    <div class="card-body max-h-72 overflow-y-auto">
      <% if @organizations.any? %>
        <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
          <%= f.collection_check_boxes :organization_ids, @organizations, :id, :name do |b| %>
            <label class="label cursor-pointer justify-start gap-2 <%= "opacity-50" if @feature.applies_to_all_organizations? %>">
              <%= b.check_box(class: "checkbox-field", disabled: @feature.applies_to_all_organizations?) %>
              <span class="label-text"><%= b.text %></span>
            </label>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-base-content/60">No organizations exist yet.</p>
      <% end %>
    </div>
  </div>
</div>

<div class="form-control mt-2">
  <%= f.submit "Save changes", class: "btn btn-primary" %>
</div>
