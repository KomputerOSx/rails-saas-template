<section class="w-full max-w-4xl">
  <p class="text-sm font-medium text-base-content/60">Admin</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">Features</h1>

  <%= form_with url: admin_features_path, method: :get, html: { class: "mt-6 flex flex-wrap items-end gap-2" } do %>
    <div class="form-control">
      <label class="label"><span class="label-text text-xs">Search</span></label>
      <input type="text" name="q" value="<%= @q %>" placeholder="Key or name" class="input-field w-56">
    </div>
    <%= submit_tag "Filter", class: "btn btn-sm btn-primary" %>
    <% if @q.present? %>
      <%= link_to "Clear", admin_features_path, class: "btn btn-sm btn-ghost" %>
    <% end %>
  <% end %>

  <div class="card mt-4 border border-base-300">
    <div class="card-body p-0">
      <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead class="text-sm font-semibold text-base-content bg-base-200">
            <tr class="border-b border-base-300">
              <th>Key</th>
              <th>Name</th>
              <th>Enabled</th>
              <th>Org opt-in required</th>
              <th>Organizations granted</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @features.each do |feature| %>
              <tr class="hover:bg-base-200">
                <td class="font-medium font-mono text-sm"><%= feature.key %></td>
                <td class="text-base-content/60"><%= feature.name %></td>
                <td>
                  <% if feature.enabled? %>
                    <span class="badge badge-success badge-sm">On</span>
                  <% else %>
                    <span class="badge badge-ghost badge-sm">Off</span>
                  <% end %>
                </td>
                <td class="text-base-content/60"><%= feature.manager_activation_required? ? "Yes" : "No" %></td>
                <td class="text-base-content/60"><%= feature.feature_organization_accesses.enabled.count %></td>
                <td>
                  <div class="flex justify-end">
                    <%= link_to "Edit", edit_admin_feature_path(feature), class: "link link-primary" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <% if @features.none? %>
          <p class="px-8 py-6 text-sm text-base-content/60">No features match your search.</p>
        <% end %>
      </div>
    </div>
  </div>
</section>
