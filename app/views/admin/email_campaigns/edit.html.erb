<section class="w-full max-w-4xl">
  <div class="flex items-start justify-between">
    <div>
      <p class="text-sm font-medium text-base-content/60">
        <%= link_to "Email Campaigns", admin_email_campaigns_path, class: "hover:text-base-content" %>
        <span class="mx-1">/</span>
        <span>Edit</span>
      </p>
      <h1 class="mt-3 text-4xl font-semibold tracking-normal">Edit Email Campaign</h1>
    </div>
    <%= link_to "Back", admin_email_campaign_path(@email_campaign), class: "btn btn-outline btn-sm shrink-0" %>
  </div>

  <%= render "form", url: admin_email_campaign_path(@email_campaign), http_method: :patch, submit_label: "Save changes" %>
</section>
