<section class="w-full max-w-3xl">
  <div class="flex items-start justify-between">
    <div>
      <p class="text-sm font-medium text-base-content/60">
        <%= link_to "Permissions", admin_permissions_path, class: "hover:text-base-content" %>
        <span class="mx-1">/</span>
        <span><%= @permission.key %></span>
      </p>
      <h1 class="mt-3 text-4xl font-semibold tracking-normal font-mono"><%= @permission.key %></h1>
    </div>
    <%= link_to "Back", admin_permissions_path, class: "btn btn-outline shrink-0" %>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-2">
    <%= link_to "Edit", edit_admin_permission_path(@permission), class: "btn btn-sm btn-outline" %>
    <%= button_to "Delete permission", admin_permission_path(@permission), method: :delete,
          class: "btn btn-sm btn-error btn-outline",
          data: { turbo_confirm: "Delete the #{@permission.key} permission? This removes it from every role that has it." } %>
  </div>

  <div class="mt-8 card bg-base-200 border border-base-300/30 shadow-sm">
    <div class="card-body">
      <dl class="grid grid-cols-1 divide-y divide-base-300/30 max-w-md">
        <div class="py-3">
          <dt class="text-xs text-base-content/60">Description</dt>
          <dd class="mt-1"><%= @permission.description.presence || "—" %></dd>
        </div>
        <div class="py-3">
          <dt class="text-xs text-base-content/60">Granted by</dt>
          <dd class="mt-1 flex flex-wrap gap-1">
            <% if @permission.roles.any? %>
              <% @permission.roles.each do |role| %>
                <%= link_to role.name, admin_role_path(role), class: "badge badge-outline hover:badge-primary" %>
              <% end %>
            <% else %>
              <span class="text-base-content/50">No role has this permission yet.</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>
  </div>
</section>
