<section class="w-full max-w-2xl">
  <div class="flex items-start justify-between">
    <div>
      <p class="text-sm font-medium text-base-content/60">
        <%= link_to "Permissions", admin_permissions_path, class: "hover:text-base-content" %>
        <span class="mx-1">/</span>
        <%= link_to @permission.key, admin_permission_path(@permission), class: "hover:text-base-content" %>
        <span class="mx-1">/</span>
        <span>Edit</span>
      </p>
      <h1 class="mt-3 text-4xl font-semibold tracking-normal">Edit permission</h1>
    </div>
    <%= link_to "Back", admin_permission_path(@permission), class: "btn btn-outline btn-sm shrink-0" %>
  </div>

  <div class="mt-8 card border border-base-300">
    <div class="card-body">
      <%= form_with model: @permission, url: admin_permission_path(@permission), method: :patch, html: { class: "space-y-4" } do |f| %>
        <%= render "form", f: f %>
      <% end %>
    </div>
  </div>
</section>
