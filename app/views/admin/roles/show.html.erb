<section class="w-full max-w-3xl">
  <div class="flex items-start justify-between">
    <div>
      <p class="text-sm font-medium text-base-content/60">
        <%= link_to "Roles", admin_roles_path, class: "hover:text-base-content" %>
        <span class="mx-1">/</span>
        <span><%= @role.name %></span>
      </p>
      <h1 class="mt-3 text-4xl font-semibold tracking-normal">
        <%= @role.name %>
        <% if @role.permanent? %><span class="badge badge-ghost badge-sm align-middle">permanent</span><% end %>
      </h1>
    </div>
    <%= link_to "Back", admin_roles_path, class: "btn btn-outline btn-sm shrink-0" %>
  </div>

  <div class="mt-6 flex flex-wrap items-center gap-2">
    <%= link_to "Edit", edit_admin_role_path(@role), class: "btn btn-sm btn-outline" %>
    <% unless @role.permanent? %>
      <%= button_to "Delete role", admin_role_path(@role), method: :delete,
            class: "btn btn-sm btn-error btn-outline",
            data: { controller: "confirm-modal", action: "click->confirm-modal#confirm",
                    confirm_modal_message_value: "Delete the #{@role.name} role? This cannot be undone." } %>
    <% end %>
  </div>

  <div class="mt-8 card border border-base-300">
    <div class="card-body">
      <dl class="grid grid-cols-1 divide-y divide-base-300/30 max-w-md">
        <div class="py-3">
          <dt class="text-xs text-base-content/60">Scope</dt>
          <dd class="mt-1"><span class="badge badge-outline"><%= @role.scope %></span></dd>
        </div>
        <div class="py-3">
          <dt class="text-xs text-base-content/60">Description</dt>
          <dd class="mt-1"><%= @role.description.presence || "—" %></dd>
        </div>
        <div class="py-3">
          <dt class="text-xs text-base-content/60">Permissions</dt>
          <dd class="mt-1 flex flex-wrap gap-1">
            <% if @role.permissions.any? %>
              <% @role.permissions.each do |permission| %>
                <%= link_to permission.key, admin_permission_path(permission), class: "badge badge-outline hover:badge-primary" %>
              <% end %>
            <% else %>
              <span class="text-base-content/50">—</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>
  </div>
</section>
