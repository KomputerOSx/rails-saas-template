<section class="w-full max-w-4xl">
  <p class="text-sm font-medium text-base-content/60">Admin</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">Roles</h1>

  <div class="mt-8 card bg-base-200 border border-base-300/30 shadow-sm">
    <div class="card-body">
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Scope</th>
            <th>Permissions</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @roles.each do |role| %>
            <tr>
              <td>
                <%= role.name %>
                <% if role.permanent? %><span class="badge badge-ghost badge-sm ml-1">permanent</span><% end %>
              </td>
              <td><span class="badge badge-outline"><%= role.scope %></span></td>
              <td><%= role.permissions.map(&:key).join(", ").presence || "—" %></td>
              <td><%= link_to "View", admin_role_path(role), class: "link link-primary" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</section>
