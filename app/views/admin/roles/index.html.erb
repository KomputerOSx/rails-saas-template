<section class="w-full max-w-4xl">
  <p class="text-sm font-medium text-base-content/60">Admin</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">Roles</h1>

  <%= form_with url: admin_roles_path, method: :get, html: { class: "mt-6 flex flex-wrap items-end gap-2" } do %>
    <div class="form-control">
      <label class="label"><span class="label-text text-xs">Search</span></label>
      <input type="text" name="q" value="<%= @q %>" placeholder="Name" class="input input-bordered input-sm w-56">
    </div>
    <div class="form-control">
      <label class="label"><span class="label-text text-xs">Scope</span></label>
      <select name="scope" class="select select-bordered select-sm">
        <option value="">All scopes</option>
        <% Role.scopes.each_key do |scope| %>
          <option value="<%= scope %>" <%= "selected" if @scope == scope %>><%= scope %></option>
        <% end %>
      </select>
    </div>
    <%= submit_tag "Filter", class: "btn btn-sm btn-primary" %>
    <% if @q.present? || @scope.present? %>
      <%= link_to "Clear", admin_roles_path, class: "btn btn-sm btn-ghost" %>
    <% end %>
  <% end %>

  <div class="card mt-4 border border-base-300">
    <div class="card-body p-0">
      <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead class="text-base-content/60 text-xs uppercase tracking-wide">
            <tr class="border-b border-base-300">
              <th>Name</th>
              <th>Scope</th>
              <th>Permissions</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @roles.each do |role| %>
              <tr class="hover">
                <td class="font-medium">
                  <%= role.name %>
                  <% if role.permanent? %><span class="badge badge-ghost badge-sm ml-1">permanent</span><% end %>
                </td>
                <td><span class="badge badge-outline"><%= role.scope %></span></td>
                <td class="text-base-content/60"><%= role.permissions.map(&:key).join(", ").presence || "—" %></td>
                <td>
                  <div class="flex justify-end">
                    <%= link_to "View", admin_role_path(role), class: "link link-primary" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        <% if @roles.none? %>
          <p class="px-8 py-6 text-sm text-base-content/60">No roles match your search.</p>
        <% end %>
      </div>
    </div>
  </div>
</section>
