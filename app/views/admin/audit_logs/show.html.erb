<section class="w-full max-w-3xl">
  <p class="text-sm font-medium text-base-content/60">Admin</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal"><%= @audit_log.event_type&.humanize || "Unknown" %></h1>

  <div class="mt-8 card bg-base-200 border border-base-300/30 shadow-sm">
    <div class="card-body">
      <dl class="grid grid-cols-1 divide-y divide-base-300/30 max-w-md">
        <div class="py-3">
          <dt class="text-xs text-base-content/60">User</dt>
          <dd class="mt-1"><%= @audit_log.user&.email || "—" %></dd>
        </div>
        <div class="py-3">
          <dt class="text-xs text-base-content/60">IP address</dt>
          <dd class="mt-1"><%= @audit_log.ip_address || "—" %></dd>
        </div>
        <div class="py-3">
          <dt class="text-xs text-base-content/60">User agent</dt>
          <dd class="mt-1 break-all"><%= @audit_log.user_agent || "—" %></dd>
        </div>
        <div class="py-3">
          <dt class="text-xs text-base-content/60">When</dt>
          <dd class="mt-1"><%= @audit_log.created_at %></dd>
        </div>
        <div class="py-3">
          <dt class="text-xs text-base-content/60">Metadata</dt>
          <dd class="mt-1"><pre class="text-xs whitespace-pre-wrap"><%= JSON.pretty_generate(@audit_log.metadata || {}) %></pre></dd>
        </div>
      </dl>
    </div>
  </div>
</section>
