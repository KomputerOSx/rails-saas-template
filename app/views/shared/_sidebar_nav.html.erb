<%
  # Single source of truth for sidebar navigation. Rendered in both the desktop
  # sidebar (collapsible via [data-collapsed] on the group/sidebar container)
  # and the mobile overlay panel (always expanded - no group/sidebar ancestor).
  sections = [
    {
      title: "Workspace",
      items: [
        { icon: "home", label: "Home", path: root_path },
        { icon: "dashboard", label: "Dashboard" },
        { icon: "folder", label: "Projects" }
      ]
    }
  ]

  if Current.organization && current_membership&.roles&.any?
    sections << { title: "Organization", items: [
      { icon: "toggle_on", label: "Features", path: org_features_path },
      { icon: "hub", label: "Settings", path: org_settings_path }
    ] }
  end

  if authenticated?
    sections << { title: "Account", items: [
      { icon: "person", label: "Profile", path: profile_path },
      { icon: "credit_card", label: "Billing", path: billing_path }
    ] }
  end

  if authenticated? && current_user.system_operator?
    admin_items = [ { icon: "space_dashboard", label: "Dashboard", path: admin_root_path } ]
    admin_items << { icon: "group",         label: "Users",       path: admin_users_path }       if current_user.has_permission?("system.users.manage")
    admin_items << { icon: "shield_person", label: "Roles",       path: admin_roles_path }       if current_user.has_permission?("system.roles.manage")
    admin_items << { icon: "key",           label: "Permissions", path: admin_permissions_path } if current_user.has_permission?("system.roles.manage")
    admin_items << { icon: "toggle_on",     label: "Features",    path: admin_features_path }
    admin_items << { icon: "history",       label: "Audit Logs",  path: admin_audit_logs_path }  if current_user.has_permission?("system.audit_logs.view")
    admin_items << { icon: "payments",      label: "Price Migrations", path: new_admin_price_migration_path } if current_user.has_permission?("system.billing.manage")
    admin_items << { icon: "campaign",      label: "Notifications", path: admin_notifications_path }
    admin_items << { icon: "mail",          label: "Email Campaigns", path: admin_email_campaigns_path } if current_user.has_permission?("system.email_campaigns.manage")
    admin_items << { icon: "engineering",   label: "Maintenance", path: edit_admin_maintenance_mode_path }

    sections << { title: "Admin", items: admin_items }
  end

  row_classes = "flex h-10 items-center gap-3 rounded-lg px-2"
%>
<nav class="flex w-full flex-col p-3 text-sm select-none">
  <% sections.each_with_index do |section, section_index| %>
    <!-- Section header: fixed-height row; text when expanded, divider line when collapsed -->
    <div class="flex h-4 items-center px-2 <%= "mt-3" if section_index.positive? %>">
      <span class="truncate text-xs font-semibold uppercase tracking-wider text-base-content/45 group-data-[collapsed]/sidebar:hidden"><%= section[:title] %></span>
      <span class="hidden h-px w-full bg-base-300 group-data-[collapsed]/sidebar:block"></span>
    </div>

    <ul class="flex flex-col gap-1">
      <% section[:items].each do |item| %>
        <%
          # data-controller="tooltip" is added/removed by sidebar_controller.js so
          # tooltips only exist while the desktop sidebar is collapsed.
          tooltip_data = {
            tooltip_content: item[:label],
            tooltip_placement_value: "right",
            tooltip_arrow: "true",
            tooltip_animation_value: "fade origin",
            tooltip_size_value: "small"
          }
        %>
        <li>
          <% if item[:path] %>
            <%= link_to item[:path],
                  class: "#{row_classes} #{current_page?(item[:path]) ? "bg-base-300 text-base-content" : "text-base-content/80 hover:bg-base-200 hover:text-base-content"}",
                  data: tooltip_data do %>
              <span class="flex w-6 shrink-0 items-center justify-center">
                <span class="material-symbols-outlined !text-[22px]"><%= item[:icon] %></span>
              </span>
              <span class="min-w-0 truncate transition-opacity duration-200 group-data-[collapsed]/sidebar:opacity-0"><%= item[:label] %></span>
            <% end %>
          <% else %>
            <%= content_tag :span, class: "#{row_classes} text-base-content/40", data: tooltip_data do %>
              <span class="flex w-6 shrink-0 items-center justify-center">
                <span class="material-symbols-outlined !text-[22px]"><%= item[:icon] %></span>
              </span>
              <span class="min-w-0 truncate transition-opacity duration-200 group-data-[collapsed]/sidebar:opacity-0"><%= item[:label] %></span>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</nav>
