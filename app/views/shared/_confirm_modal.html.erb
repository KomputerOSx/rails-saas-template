<dialog id="confirm-modal" class="modal">
  <div class="modal-box max-w-sm">
    <p id="confirm-modal-message" class="font-medium leading-snug"></p>
    <div class="modal-action mt-6">
      <button id="confirm-modal-cancel" type="button" class="btn btn-ghost btn-sm">Cancel</button>
      <button id="confirm-modal-confirm" type="button" class="btn btn-sm">Confirm</button>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
