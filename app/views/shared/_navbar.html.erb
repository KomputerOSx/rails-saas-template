<nav class="navbar min-h-16 px-4 lg:px-6">
  <div class="flex-none lg:hidden">
    <label for="app-sidebar" aria-label="Open sidebar" class="btn btn-square btn-ghost text-base-content">
      <span class="material-symbols-outlined !text-[20px]">menu</span>
    </label>
  </div>

  <div class="flex-1">
    <% if authenticated? && current_user.organizations.any? %>
      <% selected_name = Current.organization&.name || current_user.organizations.first&.name.to_s %>
      <%= form_with url: org_switch_path, method: :post, data: { controller: "org-switch" } do %>
        <%= select_tag :organization_id,
              options_for_select(current_user.organizations.map { |o| [ o.name, o.id ] }, Current.organization&.id),
              class: "select select-ghost text-lg",
              style: "width: #{selected_name.length + 5}ch;",
              data: { org_switch_target: "select", action: "change->org-switch#change" } %>
      <% end %>
    <% else %>
      <%= link_to "Windtunnel", root_path, class: "btn btn-ghost text-lg font-bold normal-case text-base-content" %>
    <% end %>
  </div>

  <div class="flex items-center gap-2">
    <button data-controller="theme" data-action="click->theme#toggle" class="btn btn-ghost btn-square btn-sm" aria-label="Toggle theme">
      <span class="material-symbols-outlined !text-[20px]" data-theme-target="icon">light_mode</span>
    </button>
    <% if authenticated? %>
      <% unread_count = current_user.unread_notification_count %>
      <%= link_to notification_recipients_path, class: "btn btn-ghost btn-square btn-sm", aria: { label: "Notifications" } do %>
        <div class="indicator">
          <% if unread_count > 0 %>
            <span class="indicator-item badge badge-primary badge-xs"><%= unread_count %></span>
          <% end %>
          <span class="material-symbols-outlined !text-[20px]">notifications</span>
        </div>
      <% end %>
      <div class="hidden text-right sm:block">
        <span class="block text-xs font-medium text-base-content/50">Logged in as</span>
        <span class="block max-w-[180px] truncate text-sm font-semibold text-base-content/80"><%= current_user.email %></span>
      </div>
      <%= button_to "Logout", session_path, method: :delete, class: "btn btn-error btn-sm" %>
    <% else %>
      <%= link_to "Login", login_path, class: "btn btn-sm border-base-300 bg-base-200 text-base-content hover:border-base-content/20 hover:bg-base-300" %>
      <%= link_to "Sign up", new_registration_path, class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</nav>
