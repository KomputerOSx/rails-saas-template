<nav class="navbar min-h-16 px-4 lg:px-6">
  <div class="flex-none lg:hidden">
    <label for="app-sidebar" aria-label="Open sidebar" class="btn btn-square btn-ghost text-base-content">
      <span class="material-symbols-outlined !text-[20px]">menu</span>
    </label>
  </div>

  <div class="flex-1">
    <% if authenticated? && current_user.organizations.any? %>
      <div class="dropdown">
        <div tabindex="0" role="button" class="btn btn-ghost text-lg font-bold normal-case text-base-content gap-1">
          <%= Current.organization&.name || "Select organization" %>
          <span class="material-symbols-outlined !text-[18px]">expand_more</span>
        </div>
        <ul tabindex="0" class="dropdown-content menu z-10 mt-2 w-56 rounded-box bg-base-200 p-2 shadow">
          <% current_user.organizations.each do |organization| %>
            <li>
              <%= button_to organization.name, org_switch_path(organization_id: organization.id), method: :post,
                    class: "btn btn-ghost btn-sm w-full justify-start normal-case #{"btn-active" if organization == Current.organization}" %>
            </li>
          <% end %>
        </ul>
      </div>
    <% else %>
      <%= link_to "Windtunnel", root_path, class: "btn btn-ghost text-lg font-bold normal-case text-base-content" %>
    <% end %>
  </div>

  <div class="flex items-center gap-2">
    <button data-controller="theme" data-action="click->theme#toggle" class="btn btn-ghost btn-square btn-sm" aria-label="Toggle theme">
      <span class="material-symbols-outlined !text-[20px]" data-theme-target="icon">light_mode</span>
    </button>
    <% if authenticated? %>
      <div class="hidden text-right sm:block">
        <span class="block text-xs font-medium text-base-content/50">Signed in as</span>
        <span class="block max-w-[180px] truncate text-sm font-semibold text-base-content/80"><%= current_user.email %></span>
      </div>
      <%= button_to "Sign out", session_path, method: :delete, class: "btn btn-error btn-sm" %>
    <% else %>
      <%= link_to "Sign in", login_path, class: "btn btn-sm border-base-300 bg-base-200 text-base-content hover:border-base-content/20 hover:bg-base-300" %>
      <%= link_to "Sign up", new_registration_path, class: "btn btn-primary btn-sm" %>
    <% end %>
  </div>
</nav>
