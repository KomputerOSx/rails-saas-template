<!-- Mobile Sidebar Overlay -->
<div class="fixed inset-0 z-[60] md:hidden hidden" data-sidebar-target="mobileSidebar">
  <!-- Backdrop -->
  <div class="absolute inset-0 bg-black/50 transition-opacity duration-300" data-sidebar-target="mobileBackdrop" data-action="click->sidebar#closeMobile"></div>

  <!-- Sidebar Panel -->
  <div class="absolute inset-y-0 left-0 flex w-64 flex-col bg-base-100 shadow-xl border-r border-base-300 transition-transform duration-300 ease-out" data-sidebar-target="mobilePanel">
    <div class="flex h-14 shrink-0 items-center justify-between border-b border-base-300 px-4">
      <span class="font-bold uppercase tracking-wider">WindTunnel</span>
      <button class="btn btn-ghost btn-square btn-sm text-base-content/70" data-action="click->sidebar#closeMobile" aria-label="Close sidebar">
        <span class="material-symbols-outlined !text-[20px]">close</span>
      </button>
    </div>

    <%= render "shared/sidebar_nav" %>

    <div class="grow"></div>

    <!-- Footer: user info and logout -->
    <div class="flex flex-col gap-2 border-t border-base-300 p-3">
      <% if authenticated? %>
        <!-- User info -->
        <div class="flex items-center gap-2">
          <div class="min-w-0 flex-1">
            <div class="text-xs text-base-content/50">Logged in as</div>
            <div class="truncate text-sm font-semibold text-base-content/80"><%= current_user.email %></div>
          </div>
        </div>

        <!-- Logout button -->
        <%= button_to session_path, method: :delete, class: "flex h-10 items-center gap-3 rounded-lg px-2 hover:bg-base-200 text-error hover:text-error w-full", title: "Logout" do %>
          <span class="flex w-6 shrink-0 items-center justify-center">
            <span class="material-symbols-outlined !text-[22px]">logout</span>
          </span>
          <span class="truncate">Logout</span>
        <% end %>
      <% else %>
        <!-- Login/Sign up for unauthenticated users -->
        <div class="flex flex-col gap-2">
          <%= link_to "Login", login_path, class: "btn btn-sm border-base-300 bg-base-200 text-base-content hover:border-base-content/20 hover:bg-base-300 w-full" %>
          <%= link_to "Sign up", new_registration_path, class: "btn btn-primary btn-sm w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!--
  Desktop Sidebar
  Open and collapsed states share the exact same markup; collapsing only toggles
  [data-collapsed] which narrows the width and fades out labels. Icons sit in a
  fixed-width slot with identical padding in both states, so nothing shifts.
-->
<aside class="group/sidebar flex h-screen w-64 shrink-0 flex-col overflow-hidden border-r border-base-300 max-md:hidden data-[collapsed]:w-16 motion-safe:transition-[width] motion-safe:duration-300"
       data-sidebar-target="desktopSidebar">
  <!-- Header: brand on the left fades out; toggle button sits on the right -->
  <div class="flex h-14 shrink-0 items-center border-b border-base-300 px-4">
    <span class="min-w-0 flex-1 truncate font-bold uppercase tracking-wider transition-opacity duration-200 group-data-[collapsed]/sidebar:opacity-0">WindTunnel</span>
    <button class="btn btn-ghost btn-square btn-sm shrink-0 text-base-content/70"
            data-action="click->sidebar#toggle"
            data-tooltip-content="Expand sidebar"
            data-tooltip-placement-value="right"
            data-tooltip-arrow="true"
            data-tooltip-animation-value="fade origin"
            data-tooltip-size-value="small"
            aria-label="Toggle sidebar">
      <span class="material-symbols-outlined !text-[22px]" data-sidebar-target="toggleIcon">left_panel_close</span>
    </button>
  </div>

  <%= render "shared/sidebar_nav" %>

  <div class="grow"></div>

  <!-- Footer: user info and logout -->
  <div class="flex flex-col gap-2 border-t border-base-300 p-3">
    <% if authenticated? %>
      <!-- User info -->
      <div class="flex items-center gap-2 group-data-[collapsed]/sidebar:justify-center">
        <div class="min-w-0 flex-1 group-data-[collapsed]/sidebar:hidden">
          <div class="text-xs text-base-content/50">Logged in as</div>
          <div class="truncate text-sm font-semibold text-base-content/80"><%= current_user.email %></div>
        </div>
      </div>

      <!-- Logout button -->
      <%= button_to session_path, method: :delete, class: "flex h-10 items-center gap-3 rounded-lg px-2 hover:bg-base-200 text-error hover:text-error w-full text-sm group-data-[collapsed]/sidebar:w-10 group-data-[collapsed]/sidebar:justify-center group-data-[collapsed]/sidebar:p-0", title: "Logout" do %>
        <span class="flex w-6 shrink-0 items-center justify-center">
          <span class="material-symbols-outlined !text-[22px]">logout</span>
        </span>
        <span class="truncate transition-opacity duration-200 group-data-[collapsed]/sidebar:hidden">Logout</span>
      <% end %>
    <% else %>
      <!-- Login/Sign up for unauthenticated users -->
      <div class="flex flex-col gap-2">
        <%= link_to "Login", login_path, class: "btn btn-sm border-base-300 bg-base-200 text-base-content hover:border-base-content/20 hover:bg-base-300 w-full" %>
        <%= link_to "Sign up", new_registration_path, class: "btn btn-primary btn-sm w-full" %>
      </div>
    <% end %>
  </div>
</aside>
