<div class="modal-box">
  <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>
  <h3 class="font-bold text-lg mb-4">Edit name</h3>
  <%= form_with model: current_user, url: profile_path, method: :patch,
        html: { class: "space-y-4", data: { action: "turbo:submit-end->modal#closeOnSuccess" } } do |f| %>
    <div class="form-control">
      <%= f.label :first_name, class: "label" do %><span class="label-text">First name</span><% end %>
      <%= f.text_field :first_name, class: error_class_for(current_user, :first_name, "input-field w-full") %>
      <%= field_errors(current_user, :first_name) %>
    </div>
    <div class="form-control">
      <%= f.label :last_name, class: "label" do %><span class="label-text">Last name</span><% end %>
      <%= f.text_field :last_name, class: error_class_for(current_user, :last_name, "input-field w-full") %>
      <%= field_errors(current_user, :last_name) %>
    </div>
    <div class="form-control mt-2">
      <%= f.submit "Save", class: "btn btn-primary w-full" %>
    </div>
  <% end %>
</div>
<form method="dialog" class="modal-backdrop"><button>close</button></form>
