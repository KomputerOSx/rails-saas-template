<section class="w-full max-w-3xl">
  <p class="text-sm font-medium text-base-content/60">Account Settings</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">Profile</h1>

  <div class="mt-8 grid grid-cols-1 gap-8">
    <div class="card bg-base-200 border border-base-300/30 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-xl font-semibold mb-4">Personal Details</h2>

        <dl class="grid grid-cols-1 divide-y divide-base-300/30 max-w-md">
          <div class="py-3 flex items-center justify-between gap-4">
            <div>
              <dt class="text-xs text-base-content/60">Name</dt>
              <dd class="mt-1"><%= [ current_user.first_name, current_user.last_name ].compact_blank.join(" ").presence || "—" %></dd>
            </div>

            <div data-controller="modal">
              <button data-action="click->modal#open" class="btn btn-ghost btn-xs">Edit</button>

              <dialog data-modal-target="dialog" class="modal"<%= " open".html_safe if current_user.errors.any? %>>
                <div class="modal-box">
                  <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>

                  <h3 class="font-bold text-lg mb-4">Edit name</h3>

                  <%= form_with model: current_user, url: profile_path, method: :patch, html: { class: "space-y-4" } do |f| %>
                    <div class="form-control">
                      <%= f.label :first_name, class: "label" do %>
                        <span class="label-text">First name</span>
                      <% end %>
                      <%= f.text_field :first_name, class: error_class_for(current_user, :first_name, "input input-bordered w-full") %>
                      <%= field_errors(current_user, :first_name) %>
                    </div>

                    <div class="form-control">
                      <%= f.label :last_name, class: "label" do %>
                        <span class="label-text">Last name</span>
                      <% end %>
                      <%= f.text_field :last_name, class: error_class_for(current_user, :last_name, "input input-bordered w-full") %>
                      <%= field_errors(current_user, :last_name) %>
                    </div>

                    <div class="form-control mt-2">
                      <%= f.submit "Save", class: "btn btn-primary w-full" %>
                    </div>
                  <% end %>
                </div>
                <form method="dialog" class="modal-backdrop"><button>close</button></form>
              </dialog>
            </div>
          </div>

          <div class="py-3 flex items-center justify-between gap-4">
            <div>
              <dt class="text-xs text-base-content/60">Email</dt>
              <dd class="mt-1"><%= current_user.email %></dd>
              <% if current_user.email_change_pending? %>
                <dd class="mt-1 text-xs text-warning">
                  Pending change to <%= current_user.unconfirmed_email %>
                  <%= button_to "Cancel", profile_email_change_path, method: :delete, class: "link link-error ml-1" %>
                </dd>
              <% end %>
            </div>

            <div data-controller="modal">
              <button data-action="click->modal#open" class="btn btn-ghost btn-xs">Edit</button>

              <dialog data-modal-target="dialog" class="modal">
                <div class="modal-box">
                  <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>

                  <%= render "email_changes/frame" %>
                </div>
                <form method="dialog" class="modal-backdrop"><button>close</button></form>
              </dialog>
            </div>
          </div>

          <div class="py-3">
            <dt class="text-xs text-base-content/60">Roles</dt>
            <dd class="mt-1 flex flex-wrap gap-1">
              <% if current_user.roles.any? %>
                <% current_user.roles.each do |role| %>
                  <span class="badge badge-outline"><%= role.name %></span>
                <% end %>
              <% else %>
                <span class="text-base-content/50">—</span>
              <% end %>
            </dd>
          </div>

          <div class="py-3">
            <dt class="text-xs text-base-content/60">Last login</dt>
            <dd class="mt-1"><%= current_user.last_sign_in_at ? time_ago_in_words(current_user.last_sign_in_at) + " ago" : "—" %></dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="card bg-base-200 border border-base-300/30 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-xl font-semibold mb-4">Security</h2>

        <div class="flex items-center justify-between max-w-md">
          <div>
            <p class="font-medium">Authenticator app (TOTP)</p>
            <p class="text-sm text-base-content/60">
              <%= current_user.totp_enabled? ? "Enabled" : "Not enabled" %>
            </p>
          </div>

          <% if current_user.totp_enabled? %>
            <%= form_with url: profile_totp_path, method: :delete, html: { data: { turbo_confirm: "Enter your current password to disable authenticator app verification." } } do %>
              <div class="flex items-center gap-2">
                <input type="password" name="current_password" placeholder="Current password" class="input input-bordered input-sm" required>
                <%= submit_tag "Disable", class: "btn btn-sm btn-error btn-outline" %>
              </div>
            <% end %>
          <% else %>
            <%= link_to "Set up", new_profile_totp_path, class: "btn btn-sm btn-primary" %>
          <% end %>
        </div>
      </div>
    </div>

    <div class="card bg-error-content/5 border border-error/20 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-error text-xl font-semibold">Danger Zone</h2>
        <p class="text-sm text-base-content/70">
          Once you delete your account, there is no going back. Please be certain.
        </p>
        <div class="mt-4 flex justify-start">
          <%= button_to "Delete Account", profile_path, method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "btn btn-error btn-outline" %>
        </div>
      </div>
    </div>
  </div>
</section>
