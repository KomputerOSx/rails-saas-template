<section class="w-full max-w-3xl">
  <p class="text-sm font-medium text-base-content/60">Account Settings</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">Profile</h1>

  <div class="mt-8 grid grid-cols-1 gap-8">

    <%# ── Personal Details ── %>
    <div class="card border border-base-300">
      <div class="card-body p-0">
        <dl class="divide-y divide-base-300">

          <%= render "profile/name_editor" %>

          <div class="flex items-center justify-between px-8 py-4">
            <div>
              <dt class="text-xs text-base-content/60 uppercase tracking-wide">Email</dt>
              <dd class="mt-1 font-medium"><%= current_user.email %></dd>
              <% if current_user.email_change_pending? %>
                <dd class="mt-1 flex items-center gap-2 text-xs text-warning">
                  Pending change to <%= current_user.unconfirmed_email %>
                  <%= button_to "Cancel", profile_email_change_path, method: :delete, class: "link link-error" %>
                </dd>
              <% end %>
            </div>
            <div data-controller="modal">
              <button data-action="click->modal#open" class="btn btn-ghost btn-xs btn-square" title="Edit email">
                <span class="material-symbols-outlined" style="font-size:16px">edit</span>
              </button>
              <dialog data-modal-target="dialog" class="modal">
                <div class="modal-box">
                  <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>
                  <%= render "email_changes/frame" %>
                </div>
                <form method="dialog" class="modal-backdrop"><button>close</button></form>
              </dialog>
            </div>
          </div>

          <% if current_user.system_operator? %>
            <div class="px-8 py-4">
              <dt class="text-xs text-base-content/60 uppercase tracking-wide">Roles</dt>
              <dd class="mt-2 flex flex-wrap gap-1">
                <% current_user.roles.each do |role| %>
                  <span class=""><%= role.name %></span>
                <% end %>
              </dd>
            </div>
          <% end %>

          <div class="px-8 py-4">
            <dt class="text-xs text-base-content/60 uppercase tracking-wide">Last login</dt>
            <dd class="mt-1 font-medium">
              <%= current_user.last_sign_in_at ? time_ago_in_words(current_user.last_sign_in_at) + " ago" : "-" %>
            </dd>
          </div>

        </dl>
      </div>
    </div>

    <%# ── Security ── %>
    <div class="card border border-base-300">
      <div class="card-body p-0">
        <div class="flex items-center justify-between px-8 py-4">
          <div>
            <p class="font-medium">Authenticator app (TOTP)</p>
            <p class="text-sm text-base-content/60 mt-0.5">
              <%= current_user.totp_enabled? ? "Enabled" : "Not enabled" %>
            </p>
          </div>
          <% if current_user.totp_enabled? %>
            <%= form_with url: profile_totp_path, method: :delete, html: { data: { turbo_confirm: "Enter your current password to disable authenticator app verification." } } do %>
              <div class="flex items-center gap-2">
                <input type="password" name="current_password" placeholder="Current password" class="input-field" required>
                <%= submit_tag "Disable", class: "btn btn-sm btn-error btn-outline" %>
              </div>
            <% end %>
          <% else %>
            <%= link_to "Set up", new_profile_totp_path, class: "btn btn-sm btn-primary" %>
          <% end %>
        </div>
      </div>
    </div>

    <%# ── Danger Zone ── %>
    <div class="card border border-error">
      <div class="card-body p-0">
        <div class="flex items-center justify-between px-8 py-4">
          <div>
            <p class="font-medium text-error">Delete account</p>
            <p class="text-sm text-base-content/60 mt-0.5">Permanently removes your account and all associated data.</p>
          </div>
          <div data-controller="modal">
            <button data-action="click->modal#open" class="btn btn-error btn-outline btn-sm shrink-0">
              Delete Account
            </button>

            <dialog data-modal-target="dialog" class="modal">
              <div class="modal-box max-w-lg"
                   data-controller="deletion-confirm"
                   data-deletion-confirm-send-url-value="<%= profile_deletion_code_path %>"
                   data-deletion-confirm-expected-email-value="<%= current_user.email %>">

                <form method="dialog">
                  <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
                </form>

                <h3 class="font-bold text-lg text-error">Delete your account?</h3>

                <div class="mt-3 text-sm text-base-content/70 space-y-2">
                  <p>This is permanent and cannot be undone. Deleting your account will:</p>
                  <ul class="mt-2 list-disc list-inside space-y-1">
                    <li>Erase your profile and all personal data</li>
                    <li>Remove you from every organization you belong to</li>
                    <li>Cancel all pending invitations sent to you</li>
                    <li>Permanently delete your activity and audit history</li>
                  </ul>
                </div>

                <%= form_with url: profile_path, method: :delete, html: { class: "mt-6 space-y-4" } do |f| %>
                  <div class="form-control">
                    <label class="label">
                      <span class="label-text font-medium">Type your email address to confirm</span>
                    </label>
                    <input type="text" name="typed_confirmation" autocomplete="off"
                           placeholder="<%= current_user.email %>"
                           data-deletion-confirm-target="emailInput"
                           data-action="input->deletion-confirm#validate"
                           class="input-field w-full">
                  </div>

                  <div class="form-control">
                    <div class="flex items-center justify-between mb-1">
                      <label class="label py-0">
                        <span class="label-text font-medium">Confirmation code</span>
                      </label>
                      <button type="button"
                              data-deletion-confirm-target="sendButton"
                              data-action="click->deletion-confirm#sendCode"
                              class="btn btn-ghost btn-xs">
                        Send code to my email
                      </button>
                    </div>
                    <div data-controller="two-factor"
                         data-two-factor-autosubmit-value="false"
                         data-action="input->deletion-confirm#validate paste->deletion-confirm#validate">
                      <%= render "shared/otp_digits", autofocus: false %>
                    </div>
                    <p data-deletion-confirm-target="codeSentMessage"
                       class="hidden mt-1.5 text-xs text-success">
                      Code sent. Check your inbox.
                    </p>
                  </div>

                  <div class="flex justify-end gap-2 pt-2">
                    <button type="button" data-action="click->modal#close" class="btn btn-ghost btn-sm">
                      Cancel
                    </button>
                    <%= f.submit "Delete my account",
                          disabled: true,
                          data: { deletion_confirm_target: "submitButton" },
                          class: "btn btn-error btn-sm" %>
                  </div>
                <% end %>
              </div>
              <form method="dialog" class="modal-backdrop"><button>close</button></form>
            </dialog>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
