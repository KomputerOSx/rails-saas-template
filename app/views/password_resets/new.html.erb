<section class="mx-auto w-full max-w-md">
  <div class="card bg-base-200 shadow-sm">
    <div class="card-body">
      <h1 class="card-title text-2xl font-bold">Forgot your password?</h1>

      <p class="text-sm text-base-content text-opacity-70 mt-1">
        Enter your email address below and we'll send you instructions to reset your password.
      </p>

      <%= form_with url: password_resets_path, method: :post, html: { class: "mt-4 space-y-4" } do %>
        <div class="form-control">
          <label class="label" for="email"><span class="label-text">Email</span></label>
          <input type="email" name="email" id="email" autofocus autocomplete="email" class="input-field w-full">
        </div>

        <div class="form-control mt-2">
          <%= submit_tag "Send me reset instructions", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <div class="divider"></div>

      <div class="text-sm text-center">
        <%= link_to "Login", login_path, class: "link link-primary" %>
      </div>
    </div>
  </div>
</section>
