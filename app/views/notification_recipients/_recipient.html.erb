<li id="<%= dom_id(recipient) %>" class="py-4 flex items-start justify-between gap-4">
  <div class="min-w-0">
    <div class="flex items-center gap-2">
      <p class="font-medium"><%= recipient.notification.title %></p>
      <% if recipient.read_at.nil? %>
        <span class="badge badge-primary badge-xs">New</span>
      <% end %>
    </div>
    <p class="mt-1 text-sm text-base-content/70"><%= recipient.notification.body %></p>
    <p class="mt-1 text-xs text-base-content/50"><%= time_ago_in_words(recipient.notification.created_at) %> ago</p>
  </div>
  <div class="flex flex-none gap-2">
    <% if recipient.read_at.nil? %>
      <%= button_to "Mark read", mark_read_notification_recipient_path(recipient), method: :patch, class: "btn btn-xs btn-outline" %>
    <% end %>
    <%= button_to "Delete", notification_recipient_path(recipient), method: :delete, class: "btn btn-xs btn-error btn-outline" %>
  </div>
</li>
