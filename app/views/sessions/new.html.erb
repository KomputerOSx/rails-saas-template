<section class="mx-auto w-full max-w-md">
  <div class="card bg-base-200 shadow-sm">
    <div class="card-body">
      <h1 class="card-title text-2xl font-bold">Sign in</h1>

      <%= form_with url: login_path, method: :post, html: { class: "mt-4 space-y-4" } do %>
        <div class="form-control">
          <label class="label" for="email"><span class="label-text">Email</span></label>
          <input type="email" name="email" id="email" autofocus autocomplete="email" class="input input-bordered w-full">
        </div>

        <div class="form-control">
          <label class="label" for="password"><span class="label-text">Password</span></label>
          <input type="password" name="password" id="password" autocomplete="current-password" class="input input-bordered w-full">
        </div>

        <div class="form-control mt-2">
          <%= submit_tag "Sign in", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <div class="divider"></div>

      <div class="mt-4 flex flex-col gap-2 text-sm text-center">
        <%= link_to "Sign up", new_registration_path, class: "link link-primary" %>
        <%= link_to "Forgot your password?", new_password_reset_path, class: "link link-primary" %>
        <%= link_to "Didn't receive confirmation instructions?", new_confirmation_path, class: "link link-primary" %>
      </div>
    </div>
  </div>
</section>
