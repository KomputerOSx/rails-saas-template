<section class="mx-auto w-full max-w-5xl px-4 py-16 sm:py-24">
  <%# Hero %>
  <div class="mx-auto max-w-3xl text-center">
    <div class="inline-flex items-center gap-2 rounded-full border border-primary/25 bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
      </span>
      Introducing Windtunnel v1.0
    </div>

    <h1 class="mt-6 text-5xl font-semibold tracking-tight sm:text-6xl">
      Build your SaaS <span class="text-primary">at warp speed</span>
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-base-content/70">
      Windtunnel is a complete Ruby on Rails template with authentication, teams,
      role-based access control, and an admin panel already wired up - so you ship
      your product, not your plumbing.
    </p>

    <div class="mt-10 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <%= link_to "Get started", new_registration_path, class: "btn btn-primary" %>
      <%= link_to "Login", login_path, class: "btn btn-outline" %>
    </div>
  </div>

  <%# Feature grid %>
  <div class="mt-20 grid grid-cols-1 gap-4 text-left sm:grid-cols-2 lg:grid-cols-3">
    <div class="card border border-base-300">
      <div class="card-body">
        <span class="material-symbols-outlined text-primary !text-[28px]">shield_lock</span>
        <h3 class="mt-2 font-semibold">Secure authentication</h3>
        <p class="mt-1 text-sm text-base-content/60">Session auth, email confirmation, TOTP two-factor, and account lockout - built in from day one.</p>
      </div>
    </div>

    <div class="card border border-base-300">
      <div class="card-body">
        <span class="material-symbols-outlined text-primary !text-[28px]">key</span>
        <h3 class="mt-2 font-semibold">Role-based access</h3>
        <p class="mt-1 text-sm text-base-content/60">System and organization roles with granular permissions, manageable from the admin panel.</p>
      </div>
    </div>

    <div class="card border border-base-300">
      <div class="card-body">
        <span class="material-symbols-outlined text-primary !text-[28px]">group</span>
        <h3 class="mt-2 font-semibold">Teams and invitations</h3>
        <p class="mt-1 text-sm text-base-content/60">Multi-tenant organizations with member management, invitations, and onboarding flows.</p>
      </div>
    </div>

    <div class="card border border-base-300">
      <div class="card-body">
        <span class="material-symbols-outlined text-primary !text-[28px]">receipt_long</span>
        <h3 class="mt-2 font-semibold">Audit trail</h3>
        <p class="mt-1 text-sm text-base-content/60">Every security and account event is logged, searchable, and reviewable by admins.</p>
      </div>
    </div>

    <div class="card border border-base-300">
      <div class="card-body">
        <span class="material-symbols-outlined text-primary !text-[28px]">toggle_on</span>
        <h3 class="mt-2 font-semibold">Feature flags</h3>
        <p class="mt-1 text-sm text-base-content/60">Roll features out per organization with a registry you control from the admin panel.</p>
      </div>
    </div>

    <div class="card border border-base-300">
      <div class="card-body">
        <span class="material-symbols-outlined text-primary !text-[28px]">campaign</span>
        <h3 class="mt-2 font-semibold">System notifications</h3>
        <p class="mt-1 text-sm text-base-content/60">Broadcast announcements to your users and withdraw them when they are done.</p>
      </div>
    </div>
  </div>

  <%# Bottom CTA %>
  <div class="card mt-20 border border-base-300">
    <div class="card-body items-center py-12 text-center">
      <h2 class="text-2xl font-semibold">Launch in days, not weeks</h2>
      <p class="mt-2 max-w-xl text-sm text-base-content/60">
        Clone the template, run the setup, and start building the parts of your product
        that make it yours.
      </p>
      <%= link_to "Create your account", new_registration_path, class: "btn btn-primary mt-6" %>
    </div>
  </div>

  <p class="mt-12 text-center text-xs text-base-content/50">
    Built with Ruby on Rails, Turbo, Tailwind CSS, and DaisyUI.
  </p>
</section>
