<section class="max-w-4xl mx-auto text-center px-4 py-16 sm:py-24">
  <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-primary/20 bg-primary/5 text-xs text-primary font-medium mb-6">
    <span class="relative flex h-2 w-2">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
      <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
    </span>
    Introducing Windtunnel v1.0
  </div>

  <h1 class="text-5xl sm:text-6xl font-extrabold tracking-tight text-base-content">
    Build Your SaaS App <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">At Warp Speed</span>
  </h1>

  <p class="mt-6 text-lg sm:text-xl text-base-content/70 max-w-2xl mx-auto leading-relaxed">
    Windtunnel is the complete Ruby on Rails template with pre-configured authentication, premium components, customizable themes, and a dynamic dashboard to launch your product in days, not weeks.
  </p>

  <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
    <%= link_to "Get Started Now", new_registration_path, class: "btn btn-primary btn-lg px-8 shadow-lg shadow-primary/25 hover:shadow-primary/40 transition-all duration-300" %>
    <%= link_to "Watch Demo", login_path, class: "btn btn-outline btn-lg px-8" %>
  </div>

  <!-- Micro Features List -->
  <div class="mt-20 grid grid-cols-1 sm:grid-cols-3 gap-8 text-left">
    <div class="card bg-base-200/50 border border-base-300/30 backdrop-blur">
      <div class="card-body">
        <div class="text-primary mb-2">
          <span class="material-symbols-outlined !text-[32px]">bolt</span>
        </div>
        <h3 class="font-bold text-lg">Instant Setup</h3>
        <p class="text-sm text-base-content/60 mt-1">Pre-configured database, migrations, and routes to get you coding immediately.</p>
      </div>
    </div>

    <div class="card bg-base-200/50 border border-base-300/30 backdrop-blur">
      <div class="card-body">
        <div class="text-primary mb-2">
          <span class="material-symbols-outlined !text-[32px]">shield</span>
        </div>
        <h3 class="font-bold text-lg">Secure by Default</h3>
        <p class="text-sm text-base-content/60 mt-1">Built-in session authentication, TOTP two-factor, account lockout, and role-based access control.</p>
      </div>
    </div>

    <div class="card bg-base-200/50 border border-base-300/30 backdrop-blur">
      <div class="card-body">
        <div class="text-primary mb-2">
          <span class="material-symbols-outlined !text-[32px]">palette</span>
        </div>
        <h3 class="font-bold text-lg">Premium Theme</h3>
        <p class="text-sm text-base-content/60 mt-1">Stunning dark/light mode configurations powered by DaisyUI and modern Tailwind.</p>
      </div>
    </div>
  </div>
</section>
