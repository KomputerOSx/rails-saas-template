<section class="w-full max-w-3xl">
  <p class="text-sm font-medium text-base-content/60">Organization</p>
  <div class="mt-3 flex items-center gap-3">
    <h1 class="text-4xl font-semibold tracking-normal"><%= Current.organization.name %></h1>

    <% if current_user.has_permission?("app.organization.manage", organization: Current.organization) %>
      <div data-controller="modal">
        <button data-action="click->modal#open" class="btn btn-ghost btn-xs">Edit</button>

        <dialog data-modal-target="dialog" class="modal"<%= " open".html_safe if Current.organization.errors.any? %>>
          <div class="modal-box">
            <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>

            <h3 class="font-bold text-lg mb-4">Edit organization name</h3>

            <%= form_with model: Current.organization, url: org_organization_path, method: :patch, html: { class: "space-y-4" } do |f| %>
              <div class="form-control">
                <%= f.label :name, class: "label" do %>
                  <span class="label-text">Name</span>
                <% end %>
                <%= f.text_field :name, class: error_class_for(Current.organization, :name, "input input border border-base-300ed w-full") %>
                <%= field_errors(Current.organization, :name) %>
              </div>

              <div class="form-control mt-2">
                <%= f.submit "Save", class: "btn btn-primary w-full" %>
              </div>
            <% end %>
          </div>
          <form method="dialog" class="modal-backdrop"><button>close</button></form>
        </dialog>
      </div>
    <% end %>
  </div>

  <div class="mt-8 card border border-base-300">
    <div class="card-body">
      <h2 class="card-title text-xl font-semibold mb-4">Members</h2>

      <table class="table">
        <thead>
          <tr>
            <th>Email</th>
            <th>Roles</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @memberships.each do |membership| %>
            <tr>
              <td><%= membership.user.email %></td>
              <td class="flex flex-wrap gap-1">
                <% membership.roles.each do |role| %>
                  <span class="badge badge-outline"><%= role.name %></span>
                <% end %>
              </td>
              <td class="flex gap-2 justify-end">
                <% if membership.has_role?(Role::APP_USER, scope: :app) %>
                  <%= button_to "Promote to admin", promote_org_member_path(membership), method: :patch, class: "btn btn-xs btn-outline" %>
                <% elsif membership.has_role?(Role::APP_ADMIN, scope: :app) %>
                  <%= button_to "Demote to user", demote_org_member_path(membership), method: :patch, class: "btn btn-xs btn-outline" %>
                <% end %>
                <% if membership.user == current_user %>
                  <%= button_to "Leave", leave_org_members_path, method: :delete,
                        data: { turbo_confirm: "Leave #{Current.organization.name}?" },
                        class: "btn btn-xs btn-error btn-outline" %>
                <% elsif !membership.has_role?(Role::APP_OWNER, scope: :app) %>
                  <%= button_to "Remove", org_member_path(membership), method: :delete,
                        data: { turbo_confirm: "Remove #{membership.user.email} from #{Current.organization.name}?" },
                        class: "btn btn-xs btn-error btn-outline" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="mt-8 card border border-base-300">
    <div class="card-body">
      <h2 class="card-title text-xl font-semibold mb-4">Pending invitations</h2>

      <% if @pending_invitations.any? %>
        <table class="table">
          <thead>
            <tr>
              <th>Email</th>
              <th>Invited by</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @pending_invitations.each do |invitation| %>
              <tr>
                <td><%= invitation.email %></td>
                <td><%= invitation.invited_by&.email || "—" %></td>
                <td><%= button_to "Revoke", org_invitation_path(invitation), method: :delete, class: "btn btn-xs btn-outline" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <p class="text-base-content/60 text-sm">No pending invitations.</p>
      <% end %>

      <%= form_with url: org_invitations_path, method: :post, html: { class: "mt-6 flex items-end gap-2" } do %>
        <div class="form-control">
          <label class="label"><span class="label-text">Invite by email</span></label>
          <input type="email" name="email" required class="input input border border-base-300ed input-sm">
        </div>
        <%= submit_tag "Invite", class: "btn btn-sm btn-primary" %>
      <% end %>
    </div>
  </div>
</section>
