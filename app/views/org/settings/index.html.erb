<div class="w-full max-w-4xl">
  <div class="flex items-start justify-between">
    <div>
      <p class="text-sm font-medium text-base-content/60">Organization</p>
      <div class="mt-3 flex items-center gap-3">
        <h1 class="text-4xl font-semibold tracking-normal"><%= Current.organization.name %></h1>

        <% if current_user.has_permission?("app.organization.manage", organization: Current.organization) %>
          <div data-controller="modal">
            <button data-action="click->modal#open" class="btn btn-ghost btn-xs">
              <span class="material-symbols-outlined" style="font-size:16px">edit</span>
            </button>

            <dialog data-modal-target="dialog" class="modal"<%= " open".html_safe if Current.organization.errors.any? %>>
              <div class="modal-box">
                <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>

                <h3 class="font-bold text-lg mb-4">Edit organization name</h3>

                <%= form_with model: Current.organization, url: org_organization_path, method: :patch, html: { class: "space-y-4" } do |f| %>
                  <div class="form-control">
                    <%= f.label :name, class: "label" do %>
                      <span class="label-text">Name</span>
                    <% end %>
                    <%= f.text_field :name, class: error_class_for(Current.organization, :name, "input-field w-full") %>
                    <%= field_errors(Current.organization, :name) %>
                  </div>

                  <div class="form-control mt-2">
                    <%= f.submit "Save", class: "btn btn-primary w-full" %>
                  </div>
                <% end %>
              </div>
              <form method="dialog" class="modal-backdrop"><button>close</button></form>
            </dialog>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# ── Members ── %>
  <div class="mt-10">
    <h2 class="text-lg font-semibold">Members</h2>
    <p class="mt-0.5 text-sm text-base-content/60">People with access to this organization.</p>

    <div class="card mt-4 border border-base-300">
      <div class="card-body p-0">
      <div class="overflow-x-auto">
      <table class="table table-sm">
        <thead class="text-sm font-semibold text-base-content bg-base-200">
          <tr class="border-b border-base-300">
            <th><%= sort_link "Member", "email", current_sort: @sort, current_dir: @direction %></th>
            <th><%= sort_link "Role",   "role",  current_sort: @sort, current_dir: @direction %></th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @memberships.each do |membership| %>
            <tr class="hover:bg-base-200">
              <td class="font-medium"><%= membership.user.email %></td>

              <td>
                <% if membership.has_role?(Role::APP_OWNER, scope: :app) %>
                  <span class="badge badge-outline rounded-none badge-sm">Owner</span>
                <% else %>
                  <span class="badge badge-outline rounded-none badge-sm">
                    <%= membership.has_role?(Role::APP_ADMIN, scope: :app) ? "Admin" : "User" %>
                  </span>
                <% end %>
              </td>

              <td>
                <div class="flex justify-end gap-1">
                  <% if membership.user == current_user %>
                    <%= button_to leave_org_members_path, method: :delete,
                          data: {
                            controller: "confirm-modal",
                            action: "click->confirm-modal#confirm",
                            confirm_modal_message_value: "Leave #{Current.organization.name}?"
                          },
                          class: "btn btn-ghost btn-xs btn-square text-error",
                          title: "Leave organization" do %>
                      <span class="material-symbols-outlined" style="font-size:18px">logout</span>
                    <% end %>
                  <% elsif !membership.has_role?(Role::APP_OWNER, scope: :app) %>
                    <div data-controller="modal">
                      <button data-action="click->modal#open" class="btn btn-ghost btn-xs btn-square" title="Edit member">
                        <span class="material-symbols-outlined" style="font-size:18px">edit</span>
                      </button>

                      <dialog data-modal-target="dialog" class="modal">
                        <div class="modal-box">
                          <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>

                          <h3 class="font-bold text-lg">Edit member</h3>
                          <p class="mt-1 text-sm text-base-content/60"><%= membership.user.email %></p>

                          <fieldset class="form-control mt-4">
                            <label class="label"><span class="label-text">Role</span></label>
                            <%= form_with url: demote_org_member_path(membership), method: :patch,
                                  html: { class: "space-y-2" }, data: { controller: "auto-submit" } do %>
                              <label class="flex items-center gap-2.5 cursor-pointer">
                                <input type="radio" name="role" value="user" class="radio-field"
                                       data-action="change->auto-submit#submit"
                                       data-auto-submit-url-param="<%= demote_org_member_path(membership) %>"
                                       <%= "checked" if membership.has_role?(Role::APP_USER, scope: :app) %>>
                                <span class="text-sm font-medium">User</span>
                              </label>
                              <label class="flex items-center gap-2.5 cursor-pointer">
                                <input type="radio" name="role" value="admin" class="radio-field"
                                       data-action="change->auto-submit#submit"
                                       data-auto-submit-url-param="<%= promote_org_member_path(membership) %>"
                                       <%= "checked" if membership.has_role?(Role::APP_ADMIN, scope: :app) %>>
                                <span class="text-sm font-medium">Admin</span>
                              </label>
                            <% end %>
                          </fieldset>

                          <div class="divider my-4"></div>

                          <%= button_to "Remove from organization", org_member_path(membership), method: :delete,
                                data: {
                                  controller: "confirm-modal",
                                  action: "click->confirm-modal#confirm",
                                  confirm_modal_message_value: "Remove #{membership.user.email} from #{Current.organization.name}?"
                                },
                                class: "btn btn-error btn-outline btn-sm w-full" %>
                        </div>
                        <form method="dialog" class="modal-backdrop"><button>close</button></form>
                      </dialog>
                    </div>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
      </div>
      </div>
    </div>
  </div>

  <%# ── Pending invitations ── %>
  <div class="mt-10">
    <h2 class="text-lg font-semibold">Pending invitations</h2>
    <p class="mt-0.5 text-sm text-base-content/60">Invites waiting to be accepted.</p>

    <% if @pending_invitations.any? %>
      <div class="card mt-4 border border-base-300">
        <div class="card-body p-0">
        <div class="overflow-x-auto">
        <table class="table table-sm">
          <thead class="text-sm font-semibold text-base-content bg-base-200">
            <tr class="border-b border-base-300">
              <th>Email</th>
              <th>Invited by</th>
              <th class="text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% @pending_invitations.each do |invitation| %>
              <tr class="hover:bg-base-200">
                <td class="font-medium"><%= invitation.email %></td>
                <td class="text-base-content/60"><%= invitation.invited_by&.email || "—" %></td>
                <td>
                  <div class="flex justify-end">
                    <%= button_to org_invitation_path(invitation), method: :delete,
                          data: {
                            controller: "confirm-modal",
                            action: "click->confirm-modal#confirm",
                            confirm_modal_message_value: "Revoke invite for #{invitation.email}?"
                          },
                          class: "btn btn-ghost btn-xs btn-square text-error",
                          title: "Revoke invitation" do %>
                      <span class="material-symbols-outlined" style="font-size:18px">cancel</span>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
        </div>
        </div>
      </div>
    <% else %>
      <p class="mt-4 text-sm text-base-content/60">No pending invitations.</p>
    <% end %>

    <%= form_with url: org_invitations_path, method: :post, html: { class: "mt-6 flex items-end gap-2" } do %>
      <div class="form-control">
        <label class="label"><span class="label-text">Invite by email</span></label>
        <input type="email" name="email" required class="input-field">
      </div>
      <%= submit_tag "Invite", class: "btn btn-sm btn-primary" %>
    <% end %>
  </div>
</div>
