<%# locals: (value:) %>
<div class="flex items-center gap-1.5">
  <code class="min-w-0 truncate text-xs"><%= value %></code>
  <button type="button"
          class="btn btn-ghost btn-xs btn-square shrink-0"
          data-controller="clipboard"
          data-clipboard-text-value="<%= value %>"
          data-action="clipboard#copy"
          aria-label="Copy <%= value %>"
          title="Copy">
    <span class="material-symbols-outlined !text-[16px]" data-clipboard-target="icon">content_copy</span>
  </button>
</div>
