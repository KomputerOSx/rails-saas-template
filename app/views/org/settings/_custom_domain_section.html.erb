<div class="mt-10">
  <h2 class="text-lg font-semibold">Custom domain</h2>
  <p class="mt-0.5 text-sm text-base-content/60">Serve this organization on your own hostname.</p>

  <div class="mt-4 space-y-4">
    <% if Current.organization.custom_domain_allowed? %>
      <% if Current.organization.custom_domain.present? %>
        <div class="space-y-4"
             data-controller="custom-domain-status"
             data-custom-domain-status-url-value="<%= status_org_custom_domain_path %>">
          <div class="flex flex-wrap items-center gap-2">
            <a href="https://<%= Current.organization.custom_domain %>"
               class="link link-primary text-sm font-medium"
               target="_blank" rel="noopener">
              <%= Current.organization.custom_domain %>
            </a>
            <span class="badge badge-warning badge-sm"
                  data-custom-domain-status-target="badge">
              Checking
            </span>
          </div>

          <%= render "org/settings/custom_domain_dns" %>

          <% if current_user.has_permission?("app.organization.manage", organization: Current.organization) %>
            <%= button_to "Remove domain", org_custom_domain_path, method: :delete,
                  class: "btn btn-sm btn-error btn-outline w-fit",
                  data: {
                    controller: "confirm-modal",
                    action: "click->confirm-modal#confirm",
                    confirm_modal_message_value: "Remove this custom domain?"
                  } %>
          <% end %>
        </div>
      <% elsif current_user.has_permission?("app.organization.manage", organization: Current.organization) %>
        <%= form_with url: org_custom_domain_path, method: :post, class: "space-y-4" do %>
          <div class="form-control max-w-md">
            <label class="label" for="organization_custom_domain">
              <span class="label-text">Domain</span>
            </label>
            <input type="text" name="organization[custom_domain]" id="organization_custom_domain"
                   placeholder="app.yourdomain.com" class="input-field w-full"
                   autocomplete="off" spellcheck="false">
          </div>

          <%= render "org/settings/custom_domain_dns" %>

          <button type="submit" class="btn btn-sm btn-primary">Save domain</button>
        <% end %>
      <% else %>
        <p class="text-sm text-base-content/60">No custom domain configured.</p>
      <% end %>
    <% else %>
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm text-base-content/60">Available on the Growth plan.</p>
        <% if current_user.has_permission?("app.billing.manage", organization: Current.organization) %>
          <%= link_to "Upgrade to Growth", billing_path, class: "btn btn-sm btn-primary w-fit" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
