<div class="modal-box">
  <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>

  <h3 class="font-bold text-lg">Edit role</h3>
  <p class="mt-1 text-sm text-base-content/60"><%= membership.user.email %></p>

  <fieldset class="form-control mt-4">
    <label class="label"><span class="label-text">Role</span></label>
    <%= form_with url: demote_org_member_path(membership), method: :patch,
          html: { class: "space-y-2", data: { turbo_frame: "_top", controller: "auto-submit", action: "turbo:submit-end->modal#closeOnSuccess" } } do %>
      <label class="flex items-center gap-2.5 cursor-pointer">
        <input type="radio" name="role" value="user" class="radio-field"
               data-action="change->auto-submit#submit"
               data-auto-submit-url-param="<%= demote_org_member_path(membership) %>"
               <%= "checked" if membership.has_role?(Role::APP_USER, scope: :app) %>>
        <span class="text-sm font-medium">User</span>
      </label>
      <label class="flex items-center gap-2.5 cursor-pointer">
        <input type="radio" name="role" value="admin" class="radio-field"
               data-action="change->auto-submit#submit"
               data-auto-submit-url-param="<%= promote_org_member_path(membership) %>"
               <%= "checked" if membership.has_role?(Role::APP_ADMIN, scope: :app) %>>
        <span class="text-sm font-medium">Admin</span>
      </label>
    <% end %>
  </fieldset>

  <% if can_promote_to_owner? %>
    <div class="divider"></div>
    <div data-controller="deletion-confirm"
         data-deletion-confirm-send-url-value="<%= send_promotion_code_org_member_path(membership) %>"
         data-deletion-confirm-expected-email-value="<%= membership.user.email %>">
      <h4 class="font-semibold text-sm">Promote to owner</h4>
      <p class="mt-1 text-xs text-base-content/60">
        Owners have full control over the organization and can't be removed while they're the only one.
      </p>

      <%= form_with url: promote_to_owner_org_member_path(membership), method: :patch,
            html: { class: "mt-3 space-y-3", data: { turbo_frame: "_top" } } do %>
        <div class="form-control">
          <label class="label py-0"><span class="label-text text-xs">Type <%= membership.user.email %> to confirm</span></label>
          <input type="text" name="typed_confirmation" autocomplete="off"
                 placeholder="<%= membership.user.email %>"
                 data-deletion-confirm-target="emailInput"
                 data-action="input->deletion-confirm#validate"
                 class="input-field w-full">
        </div>

        <div class="form-control">
          <div class="flex items-center justify-between mb-1">
            <span class="label-text text-xs">Confirmation code (sent to your email)</span>
            <button type="button"
                    data-deletion-confirm-target="sendButton"
                    data-action="click->deletion-confirm#sendCode"
                    class="btn btn-ghost btn-xs">
              Send code to my email
            </button>
          </div>
          <div data-controller="two-factor"
               data-two-factor-autosubmit-value="false"
               data-action="input->deletion-confirm#validate paste->deletion-confirm#validate">
            <%= render "shared/otp_digits", autofocus: false %>
          </div>
          <p data-deletion-confirm-target="codeSentMessage" class="hidden mt-1.5 text-xs text-success">
            Code sent. Check your inbox.
          </p>
        </div>

        <button type="submit" disabled data-deletion-confirm-target="submitButton" class="btn btn-warning btn-sm w-full">
          Promote to owner
        </button>
      <% end %>
    </div>
  <% end %>
</div>
<form method="dialog" class="modal-backdrop"><button>close</button></form>
