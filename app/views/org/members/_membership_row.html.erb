<tr id="<%= dom_id(membership) %>" class="hover:bg-base-200">
  <td class="font-medium"><%= membership.user.email %></td>

  <%= render "org/members/role_badge", membership: membership %>

  <td>
    <div class="flex justify-end gap-1">
      <% if membership.user == current_user %>
        <%= button_to leave_org_members_path, method: :delete,
              data: {
                controller: "confirm-modal",
                action: "click->confirm-modal#confirm",
                confirm_modal_message_value: "Leave #{Current.organization.name}?"
              },
              class: "btn btn-ghost btn-xs btn-square text-error",
              title: "Leave organization" do %>
          <span class="material-symbols-outlined" style="font-size:18px">logout</span>
        <% end %>
      <% elsif !membership.has_role?(Role::APP_OWNER, scope: :app) %>
        <div data-controller="modal">
          <div class="dropdown dropdown-end">
            <button tabindex="0" type="button" class="btn btn-ghost btn-xs btn-square" title="Actions">
              <span class="material-symbols-outlined" style="font-size:18px">more_vert</span>
            </button>
            <ul tabindex="0" class="dropdown-content menu bg-base-200 border border-base-300 rounded-box z-10 w-40 p-2 shadow-lg">
              <li>
                <button type="button" data-action="click->modal#open">Edit role</button>
              </li>
              <li>
                <%= button_to "Remove", org_member_path(membership), method: :delete,
                      data: {
                        controller: "confirm-modal",
                        action: "click->confirm-modal#confirm",
                        confirm_modal_message_value: "Remove #{membership.user.email} from #{Current.organization.name}?"
                      },
                      class: "w-full text-left text-error" %>
              </li>
            </ul>
          </div>

          <dialog id="<%= dom_id(membership, :dialog) %>" data-modal-target="dialog" class="modal">
            <%= render "org/members/edit_dialog_content", membership: membership %>
          </dialog>
        </div>
      <% end %>
    </div>
  </td>
</tr>
