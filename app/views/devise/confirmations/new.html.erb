<section class="mx-auto w-full max-w-md">
  <div class="card bg-base-200 shadow-sm">
    <div class="card-body">
      <h1 class="card-title text-2xl font-bold">Resend confirmation</h1>

      <%= form_for(resource, as: resource_name, url: user_confirmation_path, html: { method: :post, class: "mt-4 space-y-4" }) do |f| %>
        <div class="form-control">
          <%= f.label :email, class: "label" do %>
            <span class="label-text">Email</span>
          <% end %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email), class: error_class_for(resource, :email, "input input-bordered w-full") %>
          <%= field_errors(resource, :email) %>
        </div>

        <div class="form-control mt-2">
          <%= f.submit "Resend confirmation instructions", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <div class="divider"></div>

      <div class="text-sm text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</section>
