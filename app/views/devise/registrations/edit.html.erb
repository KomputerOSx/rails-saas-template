<section class="w-full max-w-3xl">
  <p class="text-sm font-medium text-base-content/60">Account Settings</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">Profile Details</h1>

  <div class="mt-8 grid grid-cols-1 gap-8">
    <!-- Profile Edit Form -->
    <div class="card bg-base-200 border border-base-300/30 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-xl font-semibold mb-4">Edit Profile</h2>

        <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
          <div class="flex items-center gap-3 max-w-md mb-4">
            <div class="alert alert-info shadow-xs text-sm py-2 flex-1">
              <span>Currently waiting confirmation for: <strong><%= resource.unconfirmed_email %></strong></span>
            </div>
            <%= button_to "Cancel", cancel_email_change_path, method: :delete, class: "btn btn-xs btn-error btn-outline shrink-0" %>
          </div>
        <% end %>

        <%= form_for(resource, as: resource_name, url: user_registration_path, html: { method: :put, class: "space-y-6" }) do |f| %>

          <div class="form-control max-w-md">
            <%= f.label :email, class: "label" do %>
              <span class="label-text font-medium">Email Address</span>
            <% end %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: error_class_for(resource, :email, "input input-bordered w-full") %>
            <%= field_errors(resource, :email) %>
          </div>

          <div class="divider max-w-md"></div>

          <div class="form-control max-w-md">
            <%= f.label :password, class: "label flex flex-col items-start gap-0.5" do %>
              <span class="label-text font-medium">New Password</span>
              <span class="text-xs text-base-content/60 italic">Leave blank if you don't want to change it</span>
            <% end %>
            <%= f.password_field :password, autocomplete: "new-password", class: error_class_for(resource, :password, "input input-bordered w-full") %>
            <%= field_errors(resource, :password) %>
            <% if @minimum_password_length %>
              <div class="px-1 pt-1">
                <span class="text-xs text-base-content/50"><%= @minimum_password_length %> characters minimum</span>
              </div>
            <% end %>
          </div>

          <div class="form-control max-w-md">
            <%= f.label :password_confirmation, class: "label" do %>
              <span class="label-text font-medium">Confirm New Password</span>
            <% end %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: error_class_for(resource, :password_confirmation, "input input-bordered w-full") %>
            <%= field_errors(resource, :password_confirmation) %>
          </div>

          <div class="divider max-w-md"></div>

          <div class="form-control max-w-md">
            <%= f.label :current_password, class: "label flex flex-col items-start gap-0.5" do %>
              <span class="label-text font-medium text-primary">Current Password</span>
              <span class="text-xs text-base-content/60 italic">We need your current password to confirm changes</span>
            <% end %>
            <%= f.password_field :current_password, autocomplete: "current-password", class: error_class_for(resource, :current_password, "input input-bordered w-full") %>
            <%= field_errors(resource, :current_password) %>
          </div>

          <div class="form-control max-w-md mt-6">
            <%= f.submit "Save Changes", class: "btn btn-outline btn-primary w-full md:w-auto md:px-8" %>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Danger Zone Card -->
    <div class="card bg-error-content/5 border border-error/20 shadow-sm mt-4">
      <div class="card-body">
        <h2 class="card-title text-error text-xl font-semibold">Danger Zone</h2>
        <p class="text-sm text-base-content/70">
          Once you delete your account, there is no going back. Please be certain.
        </p>
        <div class="mt-4 flex justify-start">
          <%= button_to "Delete Account", user_registration_path, data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete, class: "btn btn-error btn-outline" %>
        </div>
      </div>
    </div>
  </div>
</section>
