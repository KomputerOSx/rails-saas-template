<section class="w-full max-w-3xl">
  <p class="text-sm font-medium text-base-content/60">Account Settings</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">Billing</h1>

  <% if Current.organization.over_member_limit? %>
    <div class="card mt-6 border border-warning/40 bg-warning/10">
      <div class="card-body flex-row items-center gap-3 py-4">
        <span class="material-symbols-outlined text-warning">warning</span>
        <p class="text-sm text-base-content">
          This organization is over its <%= @current_plan.name %> plan's member limit. Remove members or upgrade to keep inviting people.
        </p>
      </div>
    </div>
  <% end %>

  <%# ── Current Plan ── %>
  <div class="mt-10">
    <h2 class="text-lg font-semibold">Current plan</h2>
    <p class="mt-0.5 text-sm text-base-content/60">
      <%= @member_usage %> of <%= @member_limit %> members used.
    </p>

    <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <% @plans.each do |plan| %>
        <div class="card border <%= plan == @current_plan ? "border-primary" : "border-base-300" %>">
          <div class="card-body">
            <div class="flex items-center justify-between">
              <h3 class="font-semibold"><%= plan.name %></h3>
              <% if plan == @current_plan %>
                <span class="badge badge-primary badge-sm">Current</span>
              <% end %>
            </div>
            <p class="mt-1 text-2xl font-semibold">
              <%= plan.free? ? "Free" : "$#{plan.price_dollars}" %>
              <% unless plan.free? %><span class="text-sm font-normal text-base-content/60">/mo</span><% end %>
            </p>
            <p class="mt-1 text-sm text-base-content/60">Up to <%= plan.member_limit %> <%= "member".pluralize(plan.member_limit) %></p>

            <% if plan != @current_plan && !plan.free? %>
              <%= button_to "Upgrade", billing_checkouts_path(plan: plan.key), method: :post,
                    class: "btn btn-primary btn-sm mt-4 w-full", data: { turbo: false } %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Payment Method ── %>
  <div class="mt-10">
    <h2 class="text-lg font-semibold">Payment method</h2>
    <p class="mt-0.5 text-sm text-base-content/60">Manage your card and billing details on Stripe.</p>

    <div class="card mt-4 border border-base-300">
      <div class="card-body p-0">
        <div class="flex items-center justify-between px-8 py-4">
          <div>
            <dt class="text-xs text-base-content/60 uppercase tracking-wide">Card on file</dt>
            <% if @payment_method %>
              <dd class="mt-1 font-medium"><%= @payment_method.brand&.capitalize %> ending in <%= @payment_method.last4 %></dd>
            <% else %>
              <dd class="mt-1 text-base-content/50">No payment method on file</dd>
            <% end %>
          </div>
          <% if @has_billing_account %>
            <%= button_to "Manage billing", billing_portal_session_path, method: :post,
                  class: "btn btn-outline btn-sm", data: { turbo: false } %>
          <% else %>
            <button class="btn btn-ghost btn-sm" disabled>Add</button>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# ── Billing History ── %>
  <div class="mt-10">
    <h2 class="text-lg font-semibold">Billing history</h2>
    <p class="mt-0.5 text-sm text-base-content/60">Your organization's past invoices.</p>

    <% if @charges.present? %>
      <div class="card mt-4 border border-base-300">
        <div class="card-body p-0">
          <div class="overflow-x-auto">
            <table class="table table-sm">
              <thead class="text-sm font-semibold text-base-content bg-base-200">
                <tr class="border-b border-base-300">
                  <th>Date</th>
                  <th>Amount</th>
                  <th class="text-right">Charged to</th>
                </tr>
              </thead>
              <tbody>
                <% @charges.each do |charge| %>
                  <tr class="hover:bg-base-200">
                    <td class="text-base-content/60"><%= charge.created_at.strftime("%b %-d, %Y") %></td>
                    <td class="font-medium"><%= charge.amount_with_currency %></td>
                    <td class="text-right text-base-content/60"><%= charge.charged_to %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    <% else %>
      <p class="mt-4 text-sm text-base-content/60">No invoices yet.</p>
    <% end %>
  </div>
</section>
