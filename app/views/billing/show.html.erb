<% content_for :head do %>
  <script src="https://js.stripe.com/v3/"></script>
<% end %>

<section class="w-full max-w-3xl"
         data-controller="modal stripe-payment-method processing-overlay"
         data-stripe-payment-method-public-key-value="<%= Rails.application.credentials.dig(:stripe, :public_key) %>"
         data-stripe-payment-method-setup-intent-url-value="<%= billing_setup_intent_path %>"
         data-stripe-payment-method-default-billing-value="<%= { name: Current.organization.billing_name.to_s, address: Current.organization.stripe_billing_address || {} }.to_json %>">
  <dialog data-processing-overlay-target="overlay" class="modal">
    <div class="flex items-center gap-3 rounded-lg border border-base-300 bg-base-100 px-6 py-4">
      <span class="loading loading-spinner loading-md"></span>
      <span class="text-sm font-medium">Processing your request...</span>
    </div>
  </dialog>

  <p class="text-sm font-medium text-base-content/60">Account Settings</p>
  <h1 class="mt-3 text-4xl font-semibold tracking-normal">Billing</h1>

  <% if Current.organization.over_member_limit? %>
    <div class="card mt-6 border border-warning/40 bg-warning/10">
      <div class="card-body flex-row items-center gap-3 py-4">
        <span class="material-symbols-outlined text-warning">warning</span>
        <p class="text-sm text-base-content">
          This organization is over its <%= @current_plan.name %> plan's member limit. Remove members or upgrade to keep inviting people.
        </p>
      </div>
    </div>
  <% end %>

  <%# ── Current Plan ── %>
  <div class="mt-10">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 class="text-lg font-semibold">Current plan</h2>
        <p class="mt-0.5 text-sm text-base-content/60">
          <%= @member_usage %> of <%= @member_limit %> members used.
        </p>
      </div>

      <div class="flex shrink-0 items-center gap-2">
        <% if @current_plan.free? %>
          <div class="join">
            <% Billing::Plans::SUPPORTED_CURRENCIES.each do |currency| %>
              <%= button_to currency.upcase, billing_currency_path, method: :patch, params: { currency: currency },
                    class: "btn btn-sm join-item #{"btn-primary" if @currency == currency}", data: { controller: "loading-button" } %>
            <% end %>
          </div>
        <% else %>
          <span class="badge badge-outline badge-sm">Billed in <%= @currency.upcase %></span>
        <% end %>
      </div>
    </div>

    <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <% @plans.each do |plan| %>
        <div class="card border <%= plan == @current_plan ? "border-primary" : "border-base-300" %>">
          <div class="card-body">
            <div class="flex items-center justify-between">
              <h3 class="font-semibold"><%= plan.name %></h3>
              <% if plan == @current_plan %>
                <span class="badge badge-primary badge-sm">Current</span>
              <% end %>
            </div>
            <p class="mt-1 text-2xl font-semibold">
              <%= plan.free? ? "Free" : plan.formatted_price(@currency) %>
              <% unless plan.free? %><span class="text-sm font-normal text-base-content/60">/mo</span><% end %>
            </p>
            <p class="mt-1 text-sm text-base-content/60">Up to <%= plan.member_limit %> <%= "member".pluralize(plan.member_limit) %></p>

            <% if plan != @current_plan && !plan.free? %>
              <% label = plan.price_cents(@currency) > @current_plan.price_cents(@currency) ? "Upgrade" : "Downgrade" %>
              <% if @payment_method %>
                <%= button_to label, billing_subscription_path(plan: plan.key), method: :post,
                      class: "btn btn-primary btn-sm mt-4 w-full", data: { controller: "loading-button" } %>
              <% else %>
                <%# No card on file yet - open the same payment method dialog used below, and
                    subscribe to this plan immediately once the card is saved. %>
                <button type="button" class="btn btn-primary btn-sm mt-4 w-full"
                        data-action="click->modal#open click->stripe-payment-method#start"
                        data-stripe-payment-method-plan-param="<%= plan.key %>"
                        data-stripe-payment-method-plan-name-param="<%= plan.name %>"
                        data-stripe-payment-method-plan-price-param="<%= plan.formatted_price(@currency) %>">
                  <%= label %>
                </button>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Payment Method ── %>
  <div class="mt-10">
    <h2 class="text-lg font-semibold">Payment method</h2>
    <p class="mt-0.5 text-sm text-base-content/60">Your card is billed automatically each cycle.</p>

    <div class="card mt-4 border border-base-300">
      <div class="card-body p-0">
        <div class="flex items-center justify-between px-8 py-4">
          <%= render "billing/payment_method_display", payment_method: @payment_method %>

          <button data-action="click->modal#open click->stripe-payment-method#start" class="btn btn-outline btn-sm shrink-0">
            Update payment method
          </button>
        </div>
      </div>
    </div>
  </div>

  <%# ── Billing Details ── %>
  <div class="mt-10" data-controller="modal">
    <h2 class="text-lg font-semibold">Billing details</h2>
    <p class="mt-0.5 text-sm text-base-content/60">The name and address that appear on your invoices.</p>

    <div class="card mt-4 border border-base-300">
      <div class="card-body p-0">
        <div class="flex items-center justify-between px-8 py-4">
          <%= render "billing/billing_address_display", organization: Current.organization %>

          <button data-action="click->modal#open" class="btn btn-outline btn-sm shrink-0">
            Edit
          </button>
        </div>
      </div>
    </div>

    <dialog data-modal-target="dialog" class="modal">
      <div class="modal-box">
        <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>
        <h3 class="font-bold text-lg">Billing details</h3>

        <%= form_with model: Current.organization, url: billing_billing_address_path, method: :patch,
              data: { action: "turbo:submit-end->modal#closeOnSuccess" } do |f| %>
          <div class="form-control mt-4">
            <label class="label"><span class="label-text">Name</span></label>
            <%= f.text_field :billing_name, class: "input-field w-full" %>
          </div>
          <div class="form-control mt-4">
            <label class="label"><span class="label-text">Address line 1</span></label>
            <%= f.text_field :billing_address_line1, class: "input-field w-full" %>
          </div>
          <div class="form-control mt-4">
            <label class="label"><span class="label-text">Address line 2</span></label>
            <%= f.text_field :billing_address_line2, class: "input-field w-full" %>
          </div>
          <div class="mt-4 grid grid-cols-2 gap-4">
            <div class="form-control">
              <label class="label"><span class="label-text">City</span></label>
              <%= f.text_field :billing_address_city, class: "input-field w-full" %>
            </div>
            <div class="form-control">
              <label class="label"><span class="label-text">State / Province</span></label>
              <%= f.text_field :billing_address_state, class: "input-field w-full" %>
            </div>
          </div>
          <div class="mt-4 grid grid-cols-2 gap-4">
            <div class="form-control">
              <label class="label"><span class="label-text">Postal code</span></label>
              <%= f.text_field :billing_address_postal_code, class: "input-field w-full" %>
            </div>
            <div class="form-control">
              <label class="label"><span class="label-text">Country</span></label>
              <%= f.text_field :billing_address_country, class: "input-field w-full", placeholder: "e.g. US" %>
            </div>
          </div>

          <%= f.button "Save", type: :submit, class: "btn btn-primary w-full mt-6", data: { controller: "loading-button" } %>
        <% end %>
      </div>
      <form method="dialog" class="modal-backdrop"><button>close</button></form>
    </dialog>
  </div>

  <%# ── Billing History ── %>
  <div class="mt-10" id="billing-history">
    <h2 class="text-lg font-semibold">Billing history</h2>
    <p class="mt-0.5 text-sm text-base-content/60">Your organization's past invoices.</p>

    <% if @charges.present? %>
      <div class="card mt-4 border border-base-300">
        <div class="card-body p-0">
          <div class="overflow-x-auto">
            <table class="table table-sm">
              <thead class="text-sm font-semibold text-base-content bg-base-200">
                <tr class="border-b border-base-300">
                  <th>Date</th>
                  <th>Amount</th>
                  <th>Charged to</th>
                  <th class="text-right">Invoice</th>
                </tr>
              </thead>
              <tbody>
                <% @charges.each do |charge| %>
                  <tr class="hover:bg-base-200">
                    <td class="text-base-content/60"><%= charge.created_at.strftime("%b %-d, %Y") %></td>
                    <td class="font-medium"><%= charge.amount_with_currency %></td>
                    <td class="text-base-content/60"><%= charge.charged_to %></td>
                    <td class="text-right">
                      <% invoice_pdf = charge.stripe_invoice.is_a?(Hash) ? charge.stripe_invoice["invoice_pdf"] : nil %>
                      <% download_url = invoice_pdf || charge.stripe_receipt_url %>
                      <% if download_url %>
                        <%= link_to "Download", download_url, class: "link link-hover text-sm", target: "_blank", rel: "noopener" %>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <% if @charges_total_pages > 1 %>
        <div class="mt-3 flex items-center justify-between">
          <p class="text-sm text-base-content/60">Page <%= @charges_page %> of <%= @charges_total_pages %></p>
          <div class="join">
            <% if @charges_page > 1 %>
              <%= link_to "Previous", billing_path(charges_page: @charges_page - 1, anchor: "billing-history"), class: "btn btn-sm join-item" %>
            <% else %>
              <button class="btn btn-sm join-item" disabled>Previous</button>
            <% end %>
            <% if @charges_page < @charges_total_pages %>
              <%= link_to "Next", billing_path(charges_page: @charges_page + 1, anchor: "billing-history"), class: "btn btn-sm join-item" %>
            <% else %>
              <button class="btn btn-sm join-item" disabled>Next</button>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="mt-4 text-sm text-base-content/60">No invoices yet.</p>
    <% end %>
  </div>

  <%# ── Cancel Subscription ── %>
  <% unless @current_plan.free? %>
    <div class="mt-10">
      <h2 class="text-lg font-semibold">Cancel subscription</h2>
      <p class="mt-0.5 text-sm text-base-content/60">
        <%= Rails.env.production? ? "You'll keep access to #{@current_plan.name} until the end of your current billing period." : "This will end your #{@current_plan.name} subscription immediately." %>
      </p>
      <%= button_to "Cancel subscription", billing_subscription_path, method: :delete,
            class: "btn btn-error btn-outline btn-sm mt-4",
            data: {
              controller: "confirm-modal loading-button", action: "click->confirm-modal#confirm",
              confirm_modal_message_value: Rails.env.production? ? "Cancel your #{@current_plan.name} subscription? You'll keep access until the end of your current billing period." : "Cancel your #{@current_plan.name} subscription? This will end it immediately."
            } %>
    </div>
  <% end %>

  <dialog id="<%= dom_id(Current.organization, :payment_method_dialog) %>" data-modal-target="dialog" class="modal">
    <%= render "billing/payment_method_dialog_content" %>
  </dialog>
</section>
