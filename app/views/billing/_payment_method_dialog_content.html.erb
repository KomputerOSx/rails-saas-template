<div class="modal-box">
  <form method="dialog"><button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2" data-action="click->modal#close">✕</button></form>

  <h3 class="font-bold text-lg" data-stripe-payment-method-target="title">Update payment method</h3>
  <p class="mt-1 text-sm text-base-content/60 hidden" data-stripe-payment-method-target="priceNotice"></p>

  <div data-stripe-payment-method-target="address" class="mt-4"></div>

  <div data-stripe-payment-method-target="elements" class="mt-4 min-h-[200px]">
    <p class="text-sm text-base-content/60">Loading payment form...</p>
  </div>

  <p data-stripe-payment-method-target="error" class="mt-2 text-sm text-error hidden"></p>

  <button type="button" data-action="click->stripe-payment-method#save"
        data-stripe-payment-method-target="submit"
        class="btn btn-primary w-full mt-4">
    Save card
  </button>

  <%= form_with url: billing_payment_method_path, method: :post,
        data: { stripe_payment_method_target: "form", action: "turbo:submit-end->modal#closeOnSuccess" }, class: "hidden" do |f| %>
    <%= f.hidden_field :setup_intent_id, data: { stripe_payment_method_target: "setupIntentField" } %>
    <%= f.hidden_field :plan, data: { stripe_payment_method_target: "planField" } %>
    <%= hidden_field_tag "billing_name", "" %>
    <%= hidden_field_tag "billing_address[line1]", "" %>
    <%= hidden_field_tag "billing_address[line2]", "" %>
    <%= hidden_field_tag "billing_address[city]", "" %>
    <%= hidden_field_tag "billing_address[state]", "" %>
    <%= hidden_field_tag "billing_address[postal_code]", "" %>
    <%= hidden_field_tag "billing_address[country]", "" %>
  <% end %>
</div>
<form method="dialog" class="modal-backdrop"><button>close</button></form>
