<div id="promo_code_widget">
  <% if promo_code_id.present? %>
    <div class="flex items-center gap-2 text-sm">
      <span class="badge badge-success badge-sm">Code applied</span>
      <span class="text-base-content/70"><%= promo_code_display %></span>
      <%= button_to "Remove", billing_promo_code_path, method: :delete, class: "link link-hover text-xs text-error" %>
    </div>
  <% else %>
    <%= form_with url: billing_promo_code_path, method: :post, class: "flex items-center gap-2" do |f| %>
      <%= f.text_field :code, placeholder: "Have a promo code?", class: "input-field input-sm max-w-[180px]" %>
      <%= f.button "Apply", type: :submit, class: "btn btn-sm btn-outline", data: { controller: "loading-button" } %>
    <% end %>
  <% end %>
</div>
