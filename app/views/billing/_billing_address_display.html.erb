<div id="<%= dom_id(organization, :billing_address_display) %>">
  <% address = organization.stripe_billing_address %>
  <% if organization.billing_name.blank? && address.blank? %>
    <p class="text-sm text-base-content/60">Not set.</p>
  <% else %>
    <p class="font-medium"><%= organization.billing_name.presence || "—" %></p>
    <% if address %>
      <p class="mt-0.5 text-sm text-base-content/60">
        <%= [ address[:line1], address[:line2] ].compact_blank.join(", ") %><br>
        <%= [ address[:city], address[:state], address[:postal_code] ].compact_blank.join(", ") %><br>
        <%= address[:country] %>
      </p>
    <% end %>
  <% end %>
</div>
