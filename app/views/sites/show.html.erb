<% content_for :title, @organization.name %>

<div class="w-full max-w-2xl px-4 py-16">
  <p class="text-sm font-medium text-base-content/60">Organization</p>
  <h1 class="mt-2 text-3xl font-semibold tracking-tight"><%= @organization.name %></h1>
  <p class="mt-2 text-sm text-base-content/60">Public site placeholder for this custom domain.</p>

  <div class="card mt-8 border border-base-300">
    <div class="card-body gap-4">
      <div>
        <p class="text-xs font-medium uppercase tracking-wide text-base-content/50">Name</p>
        <p class="mt-1 text-sm font-medium"><%= @organization.name %></p>
      </div>
      <div>
        <p class="text-xs font-medium uppercase tracking-wide text-base-content/50">Slug</p>
        <p class="mt-1 text-sm font-medium"><%= @organization.slug %></p>
      </div>
      <div>
        <p class="text-xs font-medium uppercase tracking-wide text-base-content/50">Custom domain</p>
        <p class="mt-1 text-sm font-medium"><%= @organization.custom_domain %></p>
      </div>
    </div>
  </div>
</div>
