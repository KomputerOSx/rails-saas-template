<section class="mx-auto w-full max-w-md">
  <div class="card bg-base-200 shadow-sm">
    <div class="card-body">
      <h1 class="card-title text-2xl font-bold">Confirm your email</h1>

      <p class="text-sm text-base-content/70 mt-1">
        Enter the 6-digit code we sent to <strong><%= @email %></strong>.
      </p>

      <%= form_with url: confirmations_path, method: :post, html: { class: "mt-4 space-y-4" } do %>
        <div class="form-control">
          <label class="label" for="code"><span class="label-text">6-digit code</span></label>
          <input type="text" name="code" id="code" inputmode="numeric" autocomplete="one-time-code" pattern="[0-9]{6}" maxlength="6" autofocus class="input input-bordered w-full tracking-widest text-center text-lg<%= ' input-error' if @code_error.present? %>">
          <% if @code_error.present? %>
            <p class="text-error text-xs mt-1 font-medium"><%= @code_error %></p>
          <% end %>
        </div>

        <div class="form-control mt-2">
          <%= submit_tag "Confirm", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <div class="divider"></div>

      <div class="text-sm text-center">
        <%= link_to "Sign in", login_path, class: "link link-primary" %>
      </div>
    </div>
  </div>
</section>
