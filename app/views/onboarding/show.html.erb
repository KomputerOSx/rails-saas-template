<section class="card bg-base-200 shadow-sm">
  <div class="card-body">
    <h1 class="card-title text-2xl font-bold"><%= @step.title %></h1>
    <p class="text-sm text-base-content/70 mt-1"><%= @step.description %></p>

    <%= form_with url: onboarding_step_path(@step.key), method: :patch, html: { class: "mt-6 space-y-6" } do %>
      <%= render @step.view %>

      <div class="flex items-center justify-between pt-4">
        <% if previous = Onboarding.step_before(@step.key) %>
          <%= link_to "Back", onboarding_step_path(previous.key), class: "btn btn-ghost" %>
        <% else %>
          <span></span>
        <% end %>
        <%= submit_tag Onboarding.last_step?(@step.key) ? "Finish" : "Next", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</section>
