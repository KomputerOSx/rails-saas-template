</tr>
<tr>
  <td bgcolor="<%= EmailCampaign::HEADER_FOOTER_BG %>" style="background-color: <%= EmailCampaign::HEADER_FOOTER_BG %>; padding: 16px 24px 0; text-align: center; font-family: Arial, Helvetica, sans-serif; font-size: 13px;">
    <a href="#" style="color: #ffffff; text-decoration: underline;">Help Center</a>
    <span style="color: #6cb98d;">&nbsp;&middot;&nbsp;</span>
    <a href="#" style="color: #ffffff; text-decoration: underline;">Privacy Policy</a>
    <span style="color: #6cb98d;">&nbsp;&middot;&nbsp;</span>
    <a href="#" style="color: #ffffff; text-decoration: underline;">Terms of Service</a>
