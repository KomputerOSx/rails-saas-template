<tr>
  <td style="padding: 16px 24px 20px; border-radius: 0 0 12px 12px; border-top: 1px solid #e5e7eb; text-align: center; font-family: Arial, Helvetica, sans-serif; font-size: 12px; line-height: 18px; color: #9ca3af;">
    You're receiving this email because you have an account with Windtunnel.<br>
    <% if local_assigns.fetch(:unsubscribe_url, nil) %>
      <a href="<%= unsubscribe_url %>" style="color: #9ca3af;">Manage your email preferences</a>
    <% end %>
  </td>
</tr>
