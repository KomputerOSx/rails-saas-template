{
	email {$ACME_EMAIL}
	on_demand_tls {
		ask http://127.0.0.1:3000/internal/domain_validations
		interval 2m
		burst 5
	}
}

# Primary application host (set APP_HOST in deploy env; replace placeholder before first boot).
{$APP_HOST:localhost} {
	reverse_proxy 127.0.0.1:3000
}

:443 {
	tls {
		on_demand
	}
	reverse_proxy 127.0.0.1:3000
}

:80 {
	redir https://{host}{uri} permanent
}
