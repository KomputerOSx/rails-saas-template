# smtp:
#   user_name: my-smtp-user
#   password: my-smtp-password
#
# aws:
#   access_key_id: 123
#   secret_access_key: 345

# Used as the base secret for all MessageVerifiers in Rails, including the one protecting cookies.
secret_key_base: ** autogenerated by rails or make a very long one and never save anywhere else **


# Google OAuth credentials

# 1. Go to Google Cloud Console → Credentials (https://console.cloud.google.com/apis/credentials) (create/select a project first).
# 2. Configure the OAuth consent screen (External type is fine for dev) - app name, support email.
# 3. Create Credentials → OAuth client ID → Web application.
# 4. "Authorized JavaScript origins" (optional for this server-side flow - leave blank, or if
#    Google requires an entry, use the bare origin only, no path and no trailing slash):
#      http://localhost:3000
# 5. "Authorized redirect URIs" (required - this DOES take the full callback path):
#      http://localhost:3000/auth/google_oauth2/callback
#      https://yourdomain.com/auth/google_oauth2/callback   (add for production)
# 6. Copy the Client ID and Client Secret.

google:
  client_id: ""
  client_secret: ""

# GitHub OAuth credentials

# 1. Go to https://github.com/settings/developers → OAuth Apps → New OAuth App.
# 2. Homepage URL: http://localhost:3000 (or https://yourdomain.com in production).
# 3. Authorization callback URL (full path, required):
#      http://localhost:3000/auth/github/callback
#      https://yourdomain.com/auth/github/callback   (add a second OAuth App, or update this one, for production)
# 4. Register the application, copy the Client ID, then generate and copy a Client Secret.

github:
  client_id: ""
  client_secret: ""

# Stripe billing credentials
#
# 1. https://dashboard.stripe.com/test/apikeys - copy the Publishable key and Secret key.
# 2. https://dashboard.stripe.com/test/products - create two recurring Products:
#      "Starter" at $10.00/month and "Growth" at $30.00/month.
#    Copy each Price's id (starts with "price_") into price_ids below.
# 3. https://dashboard.stripe.com/test/webhooks - add an endpoint at
#      https://yourdomain.com/pay/webhooks/stripe
#    subscribed to at least: customer.subscription.updated, customer.subscription.deleted.
#    Copy the signing secret.
# 4. Repeat steps 1-3 in live mode before going to production (https://dashboard.stripe.com/apikeys,
#    without "/test/" in the URLs).
#
# See docs/BILLING.md for the full setup guide.
stripe:
  public_key: ""
  private_key: ""
  signing_secret: ""
  price_ids:
    starter: ""
    growth: ""
